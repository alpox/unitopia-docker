// -----------------------------------------------------------------
#define X_GILDENLISTE ({ \
    "Abenteurergilde", \
    "Alchemistengilde", \
    "Bardengilde", \
    "Diebesgilde", \
    "Druidengilde", \
    "Hexenvolk", \
    "Magiergilde", \
    "Orden der Finsternis", \
    "Sehergilde", \
    "Vampyrgilde" })

mixed* get_x_gilden(string xu_uid,<object|string> usr)
{
    string *gili = X_GILDENLISTE;
    if (!check_security() || !stringp(xu_uid))
    {
        return 0;
    }
    if (objectp(usr))
    {
        if (!playerp(usr))
            return 0;
        usr = usr->query_real_name();
    }
    else if (stringp(usr))
    {
        if (!player_exists(usr))
            return 0;
    }
    else
    {
        return 0;
    }
    mixed *r2 = db_query_err("SELECT DISTINCT gilde FROM xauswertung "
        "WHERE unified_ids LIKE ?2 AND user = ?1 AND gilde NOT NULL ",
        usr,xu_uid);
    if (!sizeof(r2))
    {
        return map(gili,(: return ({0,$1}); :));
    }
    r2 = map(r2, (: $1[0]:) );
    mixed r1 = ({});
    foreach (string gil : gili)
    {
        if (member(r2,gil)!=-1)
        {
            r1 += ({({1,gil})});
        }
        else
        {
            r1 += ({({0,gil})});
        }
    }
    return r1;
}

// -----------------------------------------------------------------

string get_x_auswertung(string unified_path,<object|string> usr)
{
    if (!check_security() || !stringp(unified_path))
    {
        return 0;
    }
    if (objectp(usr))
    {
        if (!playerp(usr))
            return 0;
        usr = usr->query_real_name();
    }
    else if (stringp(usr))
    {
        if (!player_exists(usr))
            return 0;
    }
    else
    {
        return 0;
    }
    mixed r1 = db_query_err("SELECT value FROM xauswertung "
        "WHERE unified_ids = ?1 AND user = ?2",
        unified_path,usr);
    if (sizeof(r1)!= 1)
        return 0;
    return get_one_string(r1);
}

varargs int set_x_auswertung(string unified_path,<object|string> usr,
    string val, int user_type,string gilde)
{
    if (!check_security() || !stringp(unified_path))
    {
        return 0;
    }
    if (objectp(usr))
    {
        if (!playerp(usr))
            return 0;
        usr = usr->query_real_name();
    }
    else if (stringp(usr))
    {
        if (!player_exists(usr))
            return 0;
    }
    else
    {
        return 0;
    }
    mixed r1 = db_query_err("SELECT value,xw_id FROM xauswertung "
        "WHERE unified_ids = ?1 AND user = ?2",
        unified_path,usr);
    if (!val)
    {
        db_query_err("DELETE FROM xauswertung "
            "WHERE unified_ids = ?1 AND user = ?2",unified_path,usr);
    }
    else if (sizeof(r1))
    {
        if (val != r1[0][0])
        {
            db_query_err("UPDATE xauswertung "
                "SET value = ?2,zeit = ?3 "
                "WHERE xw_id = ?1",
                r1[0][1],val,time());
            return 2; // update
        }
        else
        {
            return 3; // no update necessary.
        }
    }
    else
    {
        db_query_err("INSERT INTO xauswertung "
            "(unified_ids,value,zeit,user,user_type,gilde) "
            "VALUES (?,?,?,?,?,?)",
            unified_path,val,time(),usr,user_type,gilde||"");
        return 1; // insert
    }
}

#endif
// -----------------------------------------------------------------

int sql(string sql)
{
    mixed * m;
    if (!check_security(CHECK_ERROR)) {
        //META_D_WARN("sql() security2 failed.",0,"statistik");
        return 0;
    }
    if (!TI || !wizp(TI) || !query_all_access(TI)) {
        //META_D_WARN("sql() security1 failed.",TI,"statistik");
        return 0;
    }

    m = db_query(sql||"");
    
    if(!m) send_message_to(TP,MT_NOTIFY,MA_USE,
       wrap("Es gab keine Rückgabe."));
    else if(!pointerp(m)) send_message_to(TP,MT_NOTIFY,MA_USE,
       wrap(sprintf("Der Rückgabewert war: '%O'",m)));
    else if(sizeof(m)==0) send_message_to(TP,MT_NOTIFY,MA_USE,
       wrap("Die Tabelle ist (noch) leer."));
    else 
       TP->more (map(
  build_table ( transpose_array(map(m,(: map($1,(: to_string($1) :)) :))),
                      ({"|","-"})
                ), (: space($1) :))
       );
    if(query_db_error()) 
       send_message_to(TP,MT_NOTIFY,MA_USE,
          wrap("Es gab folgenden Fehler: "+ query_db_error()));
    return 1;
}

int tablelist(string str)
{
    check_security(CHECK_ERROR);
    string tb = space(str);
    if (tb == "") {
        return sql("SELECT name FROM sqlite_master WHERE type = 'table'");
    } else {
        return sql("SELECT sql FROM sqlite_master WHERE NAME = '"+tb+"'");
    }
}

