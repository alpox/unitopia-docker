public string query_database_description()
{
    return "Diese Datenbank dient zur Verwaltung von Ideen und Umfragen. "
    "Zum Verwalten gibt es /room/rathaus/obj/uiko. " 
    "Für Admins gibt es speziell die Lfuns sql und db_get_table.";
}

private void init_db()
