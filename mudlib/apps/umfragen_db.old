// -----------------------------------------------------------------
int aktualisiere_diskussion_status(int d_id, int st)
{
    if (!check_security() || !check_status(st))
    {
        return 0;
    }
    db_query("UPDATE diskussion SET status = ? WHERE d_id = ?",
                st, d_id);
    return 1;
}



private int check_diskussion_was(string was)
{
    switch (was)
    {
    case "ideen": return 1;
    default:      return 0;
    }
}

private int check_d_id(int d_id, int* valid_status)
{
    mixed * result = 
            db_query("SELECT status FROM diskussion WHERE d_id = ?",
            d_id);
    if (query_db_error())
        return 0;
    int st = get_one_int(result);
    return (!pointerp(valid_status) && st > 0)
           || (member(valid_status,st)!=-1);
}


int add_diskussion(string was, int id, int pantheon, int st)
{
    mixed * r1;
    string q;
    int d_id;
    if (!check_security() || !check_diskussion_was(was) || id <= 0 
            || pantheon < 0 || pantheon > 1 || !check_status(st))
    {
        return 0;
    }
    q = "SELECT COUNT(d_id) FROM diskussion ";
    q+= "WHERE was = ? AND id = ? AND pantheon = ? ";
    r1 = db_query(q,was,id,pantheon);
    if (query_db_error()) 
    {
        return -2; // DB oder Queryfehler.
    }
    if (get_one_int(r1) == 1)
    {
        return -1; // schon vorhanden.
    }
    // TODO geloeschte Diskussion wiederverwenden.
    d_id = increment_counter("d_id");
    q = "INSERT INTO diskussion(d_id, was, id, pantheon, status) ";
    q+= "VALUES (?,?,?,?,?) ";
    db_query(q,d_id,was,id,pantheon,st);
    if (query_db_error()) 
    {
        return -2; // DB oder Queryfehler.
    }
    return 1; // alles ok.
}

int add_diskussionsbeitrag(int d_id, string wer, string titel, string inhalt)
{
    string q;
    int b_id;
    if (!check_security() || d_id < 0 || !stringp(wer) || !stringp(titel)
            || !stringp(inhalt))
    {
        return 0;
    }
    if (!check_d_id(d_id, ({
                UMFRAGE_S_BEREIT, 
                UMFRAGE_S_AKTIV, 
                UMFRAGE_S_OFFEN}) ))
    {
        return -1; // d_id kein gueltiger Status
    }
    // TODO geloeschte Eintraege wiederverwenden
    b_id = increment_counter("b_id");
    q = "INSERT INTO diskussionsbeitraege ";
    q+= "(b_id, d_id, wann, wer, titel, inhalt) ";
    q+= "VALUES (?, ?, ?, ?, ?, ?) ";
    db_query(q, b_id, d_id, time(), wer, titel, inhalt);
    if (query_db_error()) 
    {
        return -2; // DB oder Queryfehler.
    }
    return 1; // alles ok.
}

int delete_diskussionsbeitrag(int b_id)
{
    if (!check_security() || b_id <= 0)
    {
        return 0;
    }
    string q = "UPDATE diskussionsbeitrag ";
    q+= "SET d_id = 0, status = ? WHERE b_id = ? ";
    db_query(q, UMFRAGE_S_GELOESCHT, b_id);
    if (query_db_error()) 
    {
        return 0; // DB oder Queryfehler.
    }
    return 1; // alles ok.
}

int ist_idee_ungelesen(mapping options, string wer)
{
    string q;
    mixed r1;
    int i, *st_arr;
    if (!check_security())
    {
        return 0;
    }
    options ||= ([]);
    q = "SELECT COUNT(b.b_id) ";
    q+= "FROM ideen i, diskussion d, diskussionsbeitraege b ";
    q+= "WHERE i.i_id = d.id AND d.was ='ideen' AND b.d_id = d.d_id ";
    if (member(options,UI_OPT_I_ID))
    {
        q+= "AND i.i_id = "+options[UI_OPT_I_ID]+" ";
    }
    else
    {
        return 0; // id muss angegeben sein.
    }
    if (options[UI_OPT_PANTHEON] == 0)
    {
        q+= "AND d.pantheon = 0 ";
    }
    if (pointerp(options[UI_OPT_STATUS]) 
        && sizeof(st_arr =options[UI_OPT_STATUS]) )
    {
        q+= "AND d.status IN (";
        for (i=0; i< sizeof(st_arr); i++)
        {
            if (i>0) q+=",";
            q+=st_arr[i];
        }
        q+= ") ";
    }
    q+= "AND b.b_id NOT IN (SELECT id FROM gelesen ";
    q+= "WHERE was ='beitraege' AND wer = '"+wer+"') ";
    r1 = db_query(q);
    //PDBG(sprintf("ist_idee_ungelesen %s=>%Q",q,r1));
    return !query_db_error() && (get_one_int(r1) > 0);
}

int ist_diskussion_ungelesen(int d_id, string wer)
{
    string q;
    int count1,count2;
    if (!check_security())
    {
        return 0;
    }
    q = "SELECT COUNT(b.b_id) FROM diskussionsbeitraege b ";
    q+= "WHERE b.d_id = ? ";
    count1 = get_one_int(db_query(q,d_id));
    //PDBG(sprintf("ist_diskussion_ungelesen %s=>%Q",q,query_db_error()));
    q = "SELECT COUNT(g.id) FROM gelesen g ";
    q+= "WHERE g.was = 'beitraege' AND g.id IN ";
    q+= "(SELECT b.b_id FROM diskussionsbeitraege b WHERE b.d_id = ?) ";
    q+= "AND g.wer = ? ";
    count2 = get_one_int(db_query(q,d_id,wer));
    //PDBG(sprintf("ist_diskussion_ungelesen %s=>%Q",q,query_db_error()));
    //PDBG(sprintf("ist_diskussion_ungelesen %d %d",count1,count2));
    return count1 > count2;
}

int ist_beitrag_ungelesen(int b_id, string wer)
{
    string q;
    mixed r1;
    if (!check_security())
    {
        return 0;
    }
    q = "SELECT b.b_id, g.wer FROM diskussionsbeitraege b ";
    q+= "LEFT JOIN gelesen g ON (b.b_id = g.id AND g.was ='beitraege' ";
    q+= "AND g.wer = ?) WHERE b.b_id = ? ";
    r1 = db_query(q,wer,b_id);
    //PDBG(sprintf("ist_beitrag_ungelesen %s=>%Q",q,r1));
    return !sizeof(r1) || r1[0][1] == 0;
}

int update_gelesen(mapping options, string wer)
{
    string q;
    if (!check_security() || !stringp(wer))
    {
        return 0;
    }
    q = "INSERT INTO gelesen (wer, was, id) ";
    if (member(options, UI_OPT_B_ID)) 
    {
        q+= "VALUES ('"+wer+"', 'beitraege', "+options[UI_OPT_B_ID] +") ";
    }
    else if (member(options, UI_OPT_D_ID)) 
    {
        q+= "SELECT '"+wer+"', 'beitraege', b.b_id ";
        q+= "FROM diskussionsbeitraege b ";
        q+= "WHERE b.d_id = "+options[UI_OPT_D_ID]+" ";
        q+= "AND b.b_id NOT IN (SELECT g.id FROM gelesen g ";
        q+= "WHERE wer ='"+wer+"' AND was = 'beitraege') ";
    }
    else if (member(options, UI_OPT_I_ID)) 
    {
        q+= "SELECT '"+wer+"', 'beitraege', b.b_id ";
        q+= "FROM diskussionsbeitraege b ";
        q+= "WHERE b.d_id IN (SELECT d.d_id FROM diskussion d ";
        q+= "WHERE id = "+options[UI_OPT_I_ID]+" AND was ='ideen') ";
        q+= "AND b.b_id NOT IN (SELECT g.id FROM gelesen g ";
        q+= "WHERE wer ='"+wer+"' AND was = 'beitraege') ";
    }
    else 
    {
        q+= "SELECT '"+wer+"', 'beitraege', b.b_id ";
        q+= "FROM diskussionsbeitraege b ";
        q+= "WHERE b.d_id IN (SELECT d.d_id FROM diskussion d ";
        q+= "WHERE id IN (SELECT i.i_id FROM ideen i WHERE 1 ";
        q = get_ideen_wahl_query(options, q);
        q+= ") AND was ='ideen') ";
        q+= "AND b.b_id NOT IN (SELECT g.id FROM gelesen g ";
        q+= "WHERE wer ='"+wer+"' AND was = 'beitraege') ";
    }
    db_query(q);
    if (query_db_error())
    {
        //PDBG(sprintf("update_gelesen %s=>%Q",q,query_db_error()));
        return 0;
    }
    return 1;
}

int update_ungelesen(mapping options, string wer)
{
    string q;
    if (!check_security() || !stringp(wer))
    {
        return 0;
    }
    q = "DELETE FROM gelesen WHERE wer ='"+wer+"' AND was ='beitraege' ";
    if (member(options, UI_OPT_B_ID)) 
    {
        q+= "AND id = "+options[UI_OPT_B_ID] +" ";
    }
    else if (member(options, UI_OPT_D_ID)) 
    {
        q+= "AND id IN (SELECT b.b_id FROM diskussionsbeitraege b ";
        q+= "WHERE b.d_id = "+options[UI_OPT_D_ID]+") ";
    }
    else if (member(options, UI_OPT_I_ID)) 
    {
        q+= "AND id IN (SELECT b.b_id FROM diskussionsbeitraege b ";
        q+= "WHERE b.d_id IN (SELECT d.d_id FROM diskussion d ";
        q+= "WHERE id = "+options[UI_OPT_I_ID]+" AND was ='ideen')) ";
    }
    else 
    {
        q+= "AND id IN (SELECT b.b_id FROM diskussionsbeitraege b ";
        q+= "WHERE b.d_id IN (SELECT d.d_id FROM diskussion d ";
        q+= "WHERE was ='ideen' AND id IN (SELECT i.i_id FROM ideen i WHERE 1 ";
        q = get_ideen_wahl_query(options, q);
        q+= "))) ";
    }
    db_query(q);
    if (query_db_error())
    {
        //PDBG(sprintf("update_ungelesen %s=>%Q",q,query_db_error()));
        return 0;
    }
    return 1;
}

mixed get_diskussionsbeitraege(mapping options)
{
    string q;
    int d_id = options[UI_OPT_D_ID];
    mixed r1;
    if (!check_security())
    {
        return 0;
    }
    if (!check_d_id(d_id, ({
                UMFRAGE_S_BEREIT, 
                UMFRAGE_S_AKTIV, 
                UMFRAGE_S_OFFEN,
                UMFRAGE_S_BEENDET,
                UMFRAGE_S_ABGELEHNT}) ))
    {
        return 0; // d_id kein gueltiger Status
    }
    if (options[UI_OPT_COUNTALL])
    {
        q = "SELECT COUNT(*) ";
    }
    else
    {
        q = "SELECT b.b_id, b.wann, b.wer, b.titel ";
    }
    q+= "FROM diskussionsbeitraege b, diskussion d ";
    q+= "WHERE b.d_id = "+d_id+" AND b.d_id = d.d_id ";
    if (options[UI_OPT_PANTHEON] == 0)
    {
        q+= "AND d.pantheon = 0 ";
    }
    if (!options[UI_OPT_COUNTALL])
    {
        // sortieren nach erhebung, titel,
        q+= "ORDER BY b.wann ";
        if (options[UI_OPT_LIMIT] > 0)
        {
            q+= "LIMIT "+options[UI_OPT_LIMIT]+" ";
        }
        if (options[UI_OPT_OFFSET] > 0)
        {
            q+= "OFFSET "+options[UI_OPT_OFFSET]+" ";
        }
    }
    r1 = db_query(q);
    //PDBG(sprintf("get_diskussionsbeitraege %s=>%Q",q,r1));
    if (query_db_error()) 
        return 0;
    if (options[UI_OPT_COUNTALL])
    {
        return get_one_int(r1);
    }
    return r1;
}

private string * get_beitragsheader(int d_id)
{
    mixed * r1;
    string q;
    if (d_id <= 0)
    {
        return ({ });
    }
    q = "SELECT d.pantheon, d.status, i.titel, i.status ";
    q+= "FROM diskussion d, ideen i ";
    q+= "WHERE i.i_id = d.id AND d.was ='ideen' AND d.d_id = "+d_id;
    r1 = db_query(q);
    //PDBG(sprintf("get_beitragsheader %s => %Q",q,r1));
    if (query_db_error() || sizeof(r1)!=1)
    {
        return ({});
    }
    return ({ sprintf("Idee: %s",r1[0][2]),
              sprintf("Diskussion: %s",
                        r1[0][0]?"Pantheon":"Spieler+Pantheon") });
}

string * get_beitrag(int b_id)
{
    mixed * r1;
    string q;
    //PDBG(sprintf("get_beitrag(%d)",b_id));
    if (!check_security() || b_id <= 0)
    {
        return 0;
    }
    q = "SELECT b.inhalt, b.d_id, b.titel ";
    q+= "FROM diskussionsbeitraege b ";
    q+= "WHERE b.b_id = "+b_id+" ";
    r1 = db_query(q);
    //PDBG(sprintf("get_beitrag: %s => %Q",q,r1));
    if (query_db_error() || sizeof(r1)!=1) 
        return 0;
    return get_beitragsheader(r1[0][1])
            +({"Titel:"+r1[0][2]})
            +explode(r1[0][0],"\n");
}

// -----------------------------------------------------------------
int ist_uiko_aktiv()
{
    return get_db_info("uiko_aktiv") == "aktiv";
}

int set_uiko_status(int an)
{
    if (!check_security() || an < 0 || an > 1)
    {
        return 0;
    }
    return set_db_info("uiko_aktiv", an?"aktiv":"inaktiv");
}

int ist_wolke_aktiv()
{
    return get_db_info("wolke_aktiv") == "aktiv";
}


int set_wolke_status(int an)
{
    if (!check_security() || an < 0 || an > 1)
    {
        return 0;
    }
    return set_db_info("wolke_aktiv", an?"aktiv":"inaktiv");
}

int set_aktuelle_idee(int i_id)
{
    if (!check_security() || i_id < 0)
    {
        return 0;
    }
    return set_db_info("aktuelle_idee", to_string(i_id));
}

mixed get_aktuelle_idee(mapping options)
{
    string tmp = get_db_info("aktuelle_idee");
    int i_id = 0;
    if (stringp(tmp))
    {
        i_id = to_int(tmp);
    }
    if (i_id <= 0)
    {
        return 0;
    }
    return get_ideen_wahl(options + ([ UI_OPT_I_ID : i_id ]));
}

int add_update(string inhalt)
{
    if (!check_security() || !stringp(inhalt))
    {
        return 0;
    }
    int version = increment_counter("version");
    if (version <= 0) 
        return 0;
    db_query("INSERT INTO updates "
        "(version, wann, was) "
        "VALUES (?,?,?)",version,time(),inhalt);
    if (query_db_error()) 
        return 0;
    // TODO nachricht...
    return 1; 
}

int get_current_version()
{
    mixed result = db_query("SELECT MAX(version) FROM updates");
    if (query_db_error()) 
        return 0;
    return get_one_int(result);
}

string * get_diff_version(int since)
{
    mixed *r = db_query(
        "SELECT was FROM updates WHERE version > ? ORDER BY version",
        since);
    if (query_db_error() || r == 0) 
        return 0;
    return map(r, (: $1[0] :));
}


