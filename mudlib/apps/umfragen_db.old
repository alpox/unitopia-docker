#ifdef UMFRAGE_EXT_GIUMF
<mixed*|int> get_xumfragen(object who, mapping options)
{
    string q;
    int u_pub,*st_arr,i;
    mixed r1;
    if (!check_security())
    {
        return 0;
    }
    u_pub = (who!=0) && (who==TI) && get_user_type(who);
    if (!u_pub)
    {
        return 0; // u_pub kein gueltiger Filter
    }
    if (options[UI_OPT_COUNTALL])
    {
        q = "SELECT COUNT(*) ";
    }
    else
    {
#define X_UMF_COLUMNS ({ \
    UI_OPT_XU_ID,UI_OPT_UNIFIED_ID,UI_OPT_TITLE,UI_OPT_DESCRIPTION, \
    UI_OPT_STATUS,UI_OPT_USER_TYPE })

        q = "SELECT xu.xu_id,xu.unified_id,xu.title,xu.description, "
            "xu.status,xu.user_type ";
    }
    q+= "FROM xumfragen xu ";
    q+= "WHERE ((xu.user_type & "+u_pub+")>0) ";
    if (options[UI_OPT_XU_ID]>0)
    {
        q+= "AND xu.xu_id = "+options[UI_OPT_XU_ID]+" ";
    }
    if (pointerp(options[UI_OPT_STATUS]) 
        && sizeof(st_arr =options[UI_OPT_STATUS]) )
    {
        q+= "AND xu.status IN (";
        for (i=0; i< sizeof(st_arr); i++)
        {
            if (i>0) q+=",";
            q+=st_arr[i];
        }
        q+= ") ";
    }
    if (!options[UI_OPT_COUNTALL])
    {
        // sortieren nach erhebung, titel,
        q+= "ORDER BY xu_id ";
        if (options[UI_OPT_LIMIT] > 0)
        {
            q+= "LIMIT "+options[UI_OPT_LIMIT]+" ";
        }
        if (options[UI_OPT_OFFSET] > 0)
        {
            q+= "OFFSET "+options[UI_OPT_OFFSET]+" ";
        }
    }
    r1 = db_query(q);
    // PDBG(sprintf("get_xumfragen %s=>%Q",q,r1));
    if (query_db_error()) 
        return 0;
    if (options[UI_OPT_COUNTALL])
    {
        return get_one_int(r1);
    }
    return r1;
}

int create_x_umfrage()
{
    if (!check_security())
    {
        return 0;
    }
    int xuid = increment_counter("xu_id");
    if (xuid <= 0) 
        return 0;
    db_query("INSERT INTO xumfragen "
        "(xu_id, status, user_type) "
        "VALUES (?,?,?)",xuid,UMFRAGE_S_NEU,UI_USER_TYPE_ADMIN);
    if (query_db_error()) 
        return 0;
    return xuid; 
}

mapping get_x_umfrage(object who, int xu_id)
{
    if (!check_security())
    {
        return 0;
    }
    mixed *r1 = get_xumfragen(who,([UI_OPT_XU_ID:xu_id]) );
    if (!sizeof(r1))
        return 0;
    return mkmapping(X_UMF_COLUMNS,r1[0]); 
}

int set_x_umfrage(object who,mapping newdata)
{
    if (!check_security())
    {
        return 0;
    }
    if (!mappingp(newdata)) 
    {
        return 0;
    }
    int xu_id = newdata[UI_OPT_XU_ID];
    mapping olddata = get_x_umfrage(who,xu_id);
    string q = "";
    if (member(newdata,UI_OPT_UNIFIED_ID)
        && stringp(newdata[UI_OPT_UNIFIED_ID]) &&
        newdata[UI_OPT_UNIFIED_ID] != olddata[UI_OPT_UNIFIED_ID])
    {
        if (q != "")
            q+= ", ";
        q+= "unified_id = '"
           +db_escape_string(newdata[UI_OPT_UNIFIED_ID])
           +"' ";
    }
    if (member(newdata,UI_OPT_TITLE)
        && stringp(newdata[UI_OPT_TITLE]) &&
        newdata[UI_OPT_TITLE] != olddata[UI_OPT_TITLE])
    {
        if (q != "")
            q+= ", ";
        q+= "title = '"
           +db_escape_string(newdata[UI_OPT_TITLE])
           +"' ";
    }
    if (member(newdata,UI_OPT_DESCRIPTION)
        && stringp(newdata[UI_OPT_DESCRIPTION]) &&
        newdata[UI_OPT_DESCRIPTION] != olddata[UI_OPT_DESCRIPTION])
    {
        if (q != "")
            q+= ", ";
        q+= "description = '"
           +db_escape_string(newdata[UI_OPT_DESCRIPTION])
           +"' ";
    }
    if (member(newdata,UI_OPT_STATUS)
        && intp(newdata[UI_OPT_STATUS]) &&
        newdata[UI_OPT_STATUS] != olddata[UI_OPT_STATUS])
    {
        if (q != "")
            q+= ", ";
        q+= "status = "+newdata[UI_OPT_STATUS]+" ";
    }
    if (member(newdata,UI_OPT_USER_TYPE)
        && intp(newdata[UI_OPT_USER_TYPE]) &&
        newdata[UI_OPT_USER_TYPE] != olddata[UI_OPT_USER_TYPE])
    {
        if (q != "")
            q+= ", ";
        q+= "user_type = "+newdata[UI_OPT_USER_TYPE]+" ";
    }
    if (q == "")
    {
        return 1;
    }
    q = "UPDATE xumfragen SET "+q+"WHERE xu_id = ?";
    db_query(q,xu_id);
    if (query_db_error())
        return 0;
    return 1;
}

