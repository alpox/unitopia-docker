<mixed*|int> get_xthemen(mapping options)
{
    string q;
    mixed r1;
    if (!check_security())
    {
        return 0;
    }
    if (options[UI_OPT_COUNTALL])
    {
        q = "SELECT COUNT(*) ";
    }
    else
    {
#define X_THEMEN_COLUMNS ({ \
    UI_OPT_XT_ID,UI_OPT_XU_ID,UI_OPT_UNIFIED_ID, \
    UI_OPT_TITLE,UI_OPT_DESCRIPTION,UI_OPT_SEQUENCE })

        q = "SELECT xt_id,xu_id,unified_id,title,description,seq ";
    }
    q+= "FROM xthemen ";
    q+= "WHERE 1=1 ";
    if (options[UI_OPT_XT_ID]>0)
    {
        q+= "AND xt_id = "+options[UI_OPT_XT_ID]+" ";
    }
    if (options[UI_OPT_XU_ID]>0)
    {
        q+= "AND xu_id = "+options[UI_OPT_XU_ID]+" ";
    }
    if (!options[UI_OPT_COUNTALL])
    {
        q+= "ORDER BY seq,xt_id ";
        if (options[UI_OPT_LIMIT] > 0)
        {
            q+= "LIMIT "+options[UI_OPT_LIMIT]+" ";
        }
        if (options[UI_OPT_OFFSET] > 0)
        {
            q+= "OFFSET "+options[UI_OPT_OFFSET]+" ";
        }
    }
    r1 = db_query(q);
    // PDBG(sprintf("get_xumfragen %s=>%Q",q,r1));
    if (query_db_error()) 
        return 0;
    if (options[UI_OPT_COUNTALL])
    {
        return get_one_int(r1);
    }
    return r1;
}

int create_x_thema(object who,int xu_id)
{
    if (!check_security())
    {
        return 0;
    }
    mapping umfrage = get_x_umfrage(who,xu_id);
    if (!mappingp(umfrage)) // TODO Status pruefen?
    {
        return 0;
    }
    int xt_id = increment_counter("xt_id");
    int seq = 1;
    if (xt_id <= 0) 
        return 0;
    mixed r2 = db_query_err("SELECT MAX(seq) FROM xthemen "
        "WHERE xu_id = ? ",xu_id);
    if (sizeof(r2)==1)
    {
        seq = get_one_int(r2)+1;
    }
    db_query("INSERT INTO xthemen "
        "(xt_id, xu_id, seq) "
        "VALUES (?,?,?)",xt_id,xu_id,seq);
    if (query_db_error()) 
        return 0;
    return xt_id; 
}

mapping get_x_thema(int xt_id)
{
    if (!check_security())
    {
        return 0;
    }
    mixed *r1 = get_xthemen(([UI_OPT_XT_ID:xt_id]) );
    if (!sizeof(r1))
        return 0;
    return mkmapping(X_THEMEN_COLUMNS,r1[0]); 
}

int set_x_thema(mapping newdata)
{
    if (!check_security())
    {
        return 0;
    }
    if (!mappingp(newdata)) 
    {
        return 0;
    }
    int xt_id = newdata[UI_OPT_XT_ID];
    mapping olddata = get_x_thema(xt_id);
    string q = "";
    if (member(newdata,UI_OPT_UNIFIED_ID)
        && stringp(newdata[UI_OPT_UNIFIED_ID]) &&
        newdata[UI_OPT_UNIFIED_ID] != olddata[UI_OPT_UNIFIED_ID])
    {
        if (q != "")
            q+= ", ";
        q+= "unified_id = '"
           +db_escape_string(newdata[UI_OPT_UNIFIED_ID])
           +"' ";
    }
    if (member(newdata,UI_OPT_TITLE)
        && stringp(newdata[UI_OPT_TITLE]) &&
        newdata[UI_OPT_TITLE] != olddata[UI_OPT_TITLE])
    {
        if (q != "")
            q+= ", ";
        q+= "title = '"
           +db_escape_string(newdata[UI_OPT_TITLE])
           +"' ";
    }
    if (member(newdata,UI_OPT_DESCRIPTION)
        && stringp(newdata[UI_OPT_DESCRIPTION]) &&
        newdata[UI_OPT_DESCRIPTION] != olddata[UI_OPT_DESCRIPTION])
    {
        if (q != "")
            q+= ", ";
        q+= "description = '"
           +db_escape_string(newdata[UI_OPT_DESCRIPTION])
           +"' ";
    }
    if (q == "")
    {
        return 1;
    }
    q = "UPDATE xthemen SET "+q+"WHERE xt_id = ?";
    db_query(q,xt_id);
    if (query_db_error())
        return 0;
    return 1;
}

mapping get_next_x_thema(int xu_id,int seq)
{
    if (!check_security())
    {
        return 0;
    }
    mixed r2 = db_query_err("SELECT xt_id,seq FROM xthemen "
            "WHERE xu_id = ?1 AND seq > ?2 ORDER BY seq,xt_id "
            "LIMIT 1",xu_id,seq);
    if (sizeof(r2)!=1)
        return 0;
    return get_x_thema(r2[0][0]);
}

int change_xthema_seq(int xt_id,int plusminus)
{
    if (!check_security())
    {
        return 0;
    }
    mapping thema1 = get_x_thema(xt_id);
    if (!mappingp(thema1))
    {
        return 0; // Fehler.
    }
    int x_seq = thema1[UI_OPT_SEQUENCE];
    mixed r2;
    if (plusminus == 1)
    {
        r2 = db_query_err("SELECT xt_id,seq FROM xthemen "
            "WHERE xu_id = ?1 AND seq > ?2 ORDER BY seq,xt_id "
            "LIMIT 1",
            thema1[UI_OPT_XU_ID],x_seq);
    }
    else if (plusminus == -1)
    {
        r2 = db_query_err("SELECT xt_id,seq FROM xthemen "
            "WHERE xu_id = ?1 AND seq < ?2 ORDER BY seq DESC,xt_id DESC "
            "LIMIT 1",
            thema1[UI_OPT_XU_ID],x_seq);
    }
    else
    {
        return 0; // fehler.
    }
    if (sizeof(r2)!=1)
    {
        return 2; // grenze erreicht.
    }
    r2 = r2[0];
    db_begin();
    db_query_err("UPDATE xthemen SET seq = ?2 "
        "WHERE xt_id = ?1 ", xt_id,r2[1]);
    db_query_err("UPDATE xthemen SET seq = ?2 "
        "WHERE xt_id = ?1 ", r2[0],x_seq);
    db_commit();
    return 1;
}

