    {
        if (q != "")
            q+= ", ";
        q+= "unified_id = '"
           +db_escape_string(newdata[UI_OPT_UNIFIED_ID])
           +"' ";
    }
    if (member(newdata,UI_OPT_ANTWORT)
        && stringp(newdata[UI_OPT_ANTWORT]) &&
        newdata[UI_OPT_ANTWORT] != olddata[UI_OPT_ANTWORT])
    {
        if (q != "")
            q+= ", ";
        q+= "antwort = '"
           +db_escape_string(newdata[UI_OPT_ANTWORT])
