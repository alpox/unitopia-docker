private int check_userinfo(string wer)
{
    mixed *r = db_query("SELECT last_time FROM userinfo WHERE wer = ?",wer);
    return (sizeof(r) > 0);
}

public int get_user_type(object who)
{
    if (!playerp(who)) return 0;
    if (adminp(who)) return UI_USER_TYPE_ADMIN;
    if (wizp(who)) return UI_USER_TYPE_WIZARD;
    if (spielerratp(who)) return UI_USER_TYPE_SR;
    if (hlpp(who)) return UI_USER_TYPE_HLP;
    if (newbiep(who)) return UI_USER_TYPE_NEWBIE;
    return UI_USER_TYPE_PLAYER;
}

public string resolve_user_status(int val)
{
    string r = "";
    if (val & UI_USER_TYPE_ADMIN) 
    {
        if (r!="") r+= ", ";
        r += "Admin";
    }
    if (val & UI_USER_TYPE_WIZARD) 
    {
        if (r!="") r+= ", ";
        r += "Gott";
    }
    if (val & UI_USER_TYPE_SR) 
    {
        if (r!="") r+= ", ";
        r += "Spielerrat";
    }
    if (val & UI_USER_TYPE_HLP) 
    {
        if (r!="") r+= ", ";
        r += "Engel";
    }
    if (val & UI_USER_TYPE_PLAYER) 
    {
        if (r!="") r+= ", ";
        r += "Spieler";
    }
    if (val & UI_USER_TYPE_NEWBIE) 
    {
        if (r!="") r+= ", ";
        r += "Newbie";
    }
    return r;
}

public int user_status2value(string str)
{
    string* split = regexplode(lower_case(space(str)),"[, ]");
    int val = 0, fail = 0;
    foreach (string utype : split)
    {
        switch(utype)
        {
            case "admin":
                val |= UI_USER_TYPE_ADMIN;
                continue;
            case "gott":
                val |= UI_USER_TYPE_WIZARD;
                continue;
            case "spielerrat":
            case "sr":
                val |= UI_USER_TYPE_SR;
                continue;
            case "engel":
            case "hlp":
                val |= UI_USER_TYPE_HLP;
                continue;
            case "spieler":
                val |= UI_USER_TYPE_PLAYER;
                continue;
            case "newbie":
                val |= UI_USER_TYPE_NEWBIE;
                continue;
            default:
                fail++;
                continue;
        }
    }
    if (val) 
        return val;
    return -1-fail;
}

private int check_status(int st)
{
    switch (st)
    {
    case UMFRAGE_S_NEU:
    case UMFRAGE_S_STANDARD:
    case UMFRAGE_S_BEREIT:
    case UMFRAGE_S_AKTIV:
    case UMFRAGE_S_OFFEN:
    case UMFRAGE_S_BEENDET:
    case UMFRAGE_S_ABGELEHNT:
    case UMFRAGE_S_ARCHIVIERT:
        return 1;
    }
    return 0;
}

private int check_u_id(int u_id, int* valid_status)
{
    mixed * result = db_query("SELECT status FROM umfragen WHERE u_id = ?",u_id);
    if (query_db_error())
        return 0;
    int st = get_one_int(result);
    return (!pointerp(valid_status) && st > 0)
           || (member(valid_status,st)!=-1);
}

int add_umfrage(string frage, string ersteller, int st,
        int i_id, int pantheon)
{
    if (!check_security() || !check_status(st) || !stringp(frage)
        ||!stringp(ersteller) || !find_player(ersteller) || i_id < 0
        || pantheon < 0 || pantheon > 1)
    {
        return 0;
    }
    int u_id;
    mixed * result = 
        db_query("SELECT u_id FROM umfragen WHERE status = 0 LIMIT 1");
    if (sizeof(result))
    {
        u_id = get_one_int(result);
        if (u_id <= 0) 
            return 0;
        db_query("UPDATE umfragen "
            "(SET frage = ?, ersteller = ?, status = ?, i_id = ?, "
            "pantheon = ? WHERE u_id = ? ",
            frage,ersteller,st,i_id,pantheon,u_id);
    }
    else
    {
        u_id = increment_counter("u_id");
        if (u_id <= 0) 
            return 0;
        db_query("INSERT INTO umfragen "
            "(u_id,frage,ersteller,status,i_id,pantheon) "
            "VALUES (?,?,?,?,?,?)",u_id,frage,ersteller,st,i_id,pantheon);
    }
    if (query_db_error()) 
        return 0;
    return u_id;
}

int add_antwort(int u_id, string antwort)
{
    if (!check_security() || !stringp(antwort))
    {
        return 0;
    }
    if (!check_u_id(u_id, ({UMFRAGE_S_NEU, 
                            UMFRAGE_S_STANDARD, 
                            UMFRAGE_S_BEREIT,
                            }) ) )
    {
        return 0;
    }
    int a_id = increment_counter("a_id");
    if (a_id <= 0) 
        return 0;
    db_query("INSERT INTO antworten "
        "(u_id,a_id,antwort) "
        "VALUES (?,?,?)",u_id,a_id,antwort);
    if (query_db_error()) 
        return 0;
    return a_id;
}

int copy_antworten(int from_u_id, int to_u_id)
{
    if (!check_security())
    {
        return 0;
    }
    if (!check_u_id(from_u_id, 0) || !check_u_id(to_u_id, ({
                            UMFRAGE_S_NEU, 
                            })))
    {
        return 0;
    }
    // nicht wenn schon antworten existieren
    mixed * result = db_query("SELECT a_id FROM antworten WHERE u_id = ?", 
            to_u_id);
    if (query_db_error() || sizeof(result))  
        return 0;
    // nicht wenn keine Antworten bei der quelle existieren
    result = db_query("SELECT antwort FROM antworten WHERE u_id = ?", 
            from_u_id);
    if (query_db_error() || !sizeof(result))  
        return 0;
    //PDBG(sprintf("copy_antworten %Q %Q",result,
    //        filter(result, (: add_antwort($2, $1[0]) :), to_u_id) ));
    return 1;
}

int hat_gewaehlt(int u_id, string wer)
{
    if (!check_security() || !stringp(wer) || !player_exists(wer))
    {
        return 0;
    }
    if (!check_u_id(u_id, 0 ) )
    {
        return 0;
    }
    mixed * result = 
        db_query("SELECT a_id FROM erhebung WHERE u_id = ? AND wer = ?",
            u_id,wer);
    if (sizeof(result)==1)
    {
        return get_one_int(result);
    }
    return 0;
}

int add_erhebung(int a_id, string wer, int pantheon)
{
    int e_id, delete_flag;
    if (!check_security() || !stringp(wer) || !find_player(wer)
            || pantheon < 0 || pantheon > 1)
    {
        return 0;
    }
    mixed r1 = db_query("SELECT u_id FROM antworten WHERE a_id = ?",a_id);
    int u_id = get_one_int(r1);
    if (!check_u_id(u_id, ({UMFRAGE_S_AKTIV }) ) )
    {
        return 0;
    }
    // vorherige Auswahl loeschen:
    delete_flag = (a_id == hat_gewaehlt(u_id,wer));
    db_query("UPDATE erhebung SET u_id = 0, wer = '', a_id = 0, pantheon = 0 "
             "WHERE u_id = ? AND wer = ?", u_id, wer);
    if (delete_flag)
    {
        return a_id;
    }
    // freie e_id suchen
    mixed * result = 
        db_query("SELECT e_id FROM erhebung WHERE u_id = 0 LIMiT 1");
    if (sizeof(result))
    {
        e_id = get_one_int(result);
        if (e_id <= 0) 
            return 0;
        db_query("DELETE FROM erhebung WHERE e_id = ?",e_id); // freigeben
    }
    else
    {
        e_id = increment_counter("e_id"); // neue e_id
        if (e_id <= 0) 
            return 0;
    }
    db_query("INSERT INTO erhebung "
        "(u_id,a_id,e_id,wer,pantheon) "
        "VALUES (?,?,?,?,?)",u_id,a_id,e_id,wer,pantheon); // neu einfuegen
    if (query_db_error()) 
        return 0;
    return a_id;
}

private int get_erhebung_pro_antwort(int a_id)
{
    mixed r = db_query("SELECT COUNT(e_id) FROM erhebung WHERE a_id = ?",
            a_id);
    if (query_db_error() || r == 0) 
        return 0;
    return get_one_int(r);
}

private string get_erhebung_pro_umfrage(int u_id)
{
    mixed r = db_query("SELECT a_id FROM antworten WHERE u_id = ?",u_id);
    string result = "";
    if (query_db_error() || r == 0) 
        return "";
    for (int i=0;i<sizeof(r);i++)
    {
        result += sprintf("%03d.",get_erhebung_pro_antwort(r[i][0]));
    }
    return strlen(result)?result[..<2]: "";
}

mixed * get_erhebung_alle_ideen(mapping options)
{
    string q;
    if (!check_security())
    {
        return 0;
    }
    options ||= ([]);
    q = "SELECT u.u_id, u.i_id, i.titel FROM umfragen u, ideen i ";
    q+= "WHERE u.i_id = i.i_id AND u.i_id > 0 ";
    q+= "AND u.status >= ? AND u.status <= ? ";
    if (options[UI_OPT_PANTHEON] == 0)
    {
        q+= "AND u.pantheon = 0 AND i.pantheon = 0 ";
    } else if (options[UI_OPT_PANTHEON] == -1)
    {
        q+= "AND (u.pantheon = 1 OR i.pantheon = 1) ";
    }
    mixed r = db_query(q, UMFRAGE_S_AKTIV, UMFRAGE_S_OFFEN);
    if (query_db_error() || r == 0 || !sizeof(r)) 
        return 0;
    mixed * result = map(r, (: 
        ({ get_erhebung_pro_umfrage($1[0]),$1[0],$1[1],$1[2] }) :) );
    return sort_array(result, (: $1[0] < $2[0] :) );
}

string * get_auswertung_prozent(int u_id)
{
    if (!check_security())
    {
        return 0;
    }
    if (!check_u_id(u_id, ({UMFRAGE_S_AKTIV,UMFRAGE_S_BEENDET,
            UMFRAGE_S_ARCHIVIERT }) ) )
    {
        return 0;
    }
    mixed * r1 = db_query(
        "SELECT COUNT(e_id) FROM erhebung WHERE u_id = ?",u_id);
    int total = get_one_int(r1);
    if (total==0) 
    {
        return ({ "Keine Stimmen." });
    }
    mixed * r2 = db_query(
        "SELECT COUNT(e.e_id), a.a_id, a.antwort "
        "FROM antworten a LEFT JOIN erhebung e "
        "WHERE e.a_id=a.a_id AND a.u_id = ? "
        "GROUP BY a.a_id, a.antwort ",
        u_id);
    if (query_db_error()) 
        return ({ query_db_error() });
    return map(r2, (: sprintf("%s=%.1f",$1[2],(100.0*$1[0])/(1.0*$2)) :), 
                total );
}

int add_idee(string titel, string inhalt, string ersteller, int st, 
             int pantheon)
{
    if (!check_security() || !check_status(st) || !stringp(titel)
        ||!stringp(inhalt) || pantheon < 0 || pantheon > 1
        ||!stringp(ersteller) || !find_player(ersteller) )
    {
        return 0;
    }
    int i_id;
    mixed * result = 
        db_query("SELECT i_id FROM ideen WHERE status = 0 LIMIT 1");
    if (sizeof(result))
    {
        i_id = get_one_int(result);
        if (i_id <= 0) 
            return 0;
        db_query("UPDATE ideen "
            "(SET titel = ?, inhalt = ?, ersteller = ?, "
            "status = ?, pantheon = ? "
            "WHERE i_id = ? ", titel, inhalt, ersteller, st, pantheon, i_id);
    }
    else
    {
        i_id = increment_counter("i_id");
        if (i_id <= 0) 
            return 0;
        db_query("INSERT INTO ideen "
            "(i_id,titel,inhalt,ersteller,status,pantheon) "
            "VALUES (?,?,?,?,?,?)",i_id,titel,inhalt,ersteller,st,pantheon);
    }
    if (query_db_error()) 
        return 0;
    return i_id;
}

int aktiviere_idee_und_umfrage(int i_id, int u_id)
{
    if (!check_security())
    {
        return 0;
    }
    // TODO transaktionskontrolle und fehlerbehandlung.
    db_query("UPDATE umfragen SET status = ? WHERE u_id = ? AND i_id = ?",
                UMFRAGE_S_BEREIT, u_id, i_id);
    db_query("UPDATE ideen SET status = ? WHERE i_id = ?",
                UMFRAGE_S_BEREIT, i_id);
    return 1;
}

