mixed get_ideen_diskussion(mapping options)
{
    mixed * r1, *r2;
    string q;
    int i_id, i, *st_arr;
    if (!check_security())
    {
        return 0;
    }
    options ||= ([]);
    if (options[UI_OPT_COUNTALL])
    {
        q = "SELECT COUNT(*) ";
    }
    else
    {
        q = "SELECT i.i_id, d.d_id, i.titel, d.pantheon ";
    }
    q+= "FROM ideen i LEFT JOIN diskussion d ";
    if (intp(i_id = options[UI_OPT_I_ID]) && i_id > 0)
    {
        if (options[UI_OPT_PANTHEON] == 0)
        {
            q+= "ON (i.i_id = d.id AND d.was ='ideen' AND d.pantheon = 0 "
                    "AND i.status <= d.status) ";
            q+= "WHERE i.i_id = "+i_id+" ";
        }
        else
        {
            q+= "WHERE d.id = i.i_id AND d.was ='ideen' "; 
            q+= "AND i.i_id = "+i_id+" ";
        }
    }
    else
    {
        return 0; // Falscher Aufruf...
    }
    if (pointerp(options[UI_OPT_STATUS]) 
        && sizeof(st_arr =options[UI_OPT_STATUS]) )
    {
        q+= "AND i.status IN (";
         for (i=0; i< sizeof(st_arr); i++)
         {
            if (i>0) q+=",";
            q+=st_arr[i];
         }
         q+= ") ";
    }
    if (pointerp(options[UI_OPT_STATUS]) 
        && sizeof(st_arr =options[UI_OPT_STATUS]) )
    {
        q+= "AND d.status IN (";
         for (i=0; i< sizeof(st_arr); i++)
         {
            if (i>0) q+=",";
            q+=st_arr[i];
         }
         q+= ") ";
    }
    if (stringp(options[UI_OPT_SUCHFILTER]))
    {
        q+= "AND (i.titel LIKE '%"+options[UI_OPT_SUCHFILTER]+"%' ";
        q+= "OR i.inhalt LIKE '%"+options[UI_OPT_SUCHFILTER]+"%') ";
    }
    if (stringp(options[UI_OPT_ERSTELLER]))
    {
        q+= "AND (u.ersteller = '"+options[UI_OPT_ERSTELLER];
        q+= "' OR i.ersteller = '"+options[UI_OPT_ERSTELLER]+"') ";
    }
    if (!options[UI_OPT_COUNTALL])
    {
        // sortieren nach erhebung, titel,
        q+= "ORDER BY i.i_id, d.d_id ";
        if (options[UI_OPT_LIMIT] > 0)
        {
            q+= "LIMIT "+options[UI_OPT_LIMIT]+" ";
        }
        if (options[UI_OPT_OFFSET] > 0)
        {
            q+= "OFFSET "+options[UI_OPT_OFFSET]+" ";
        }
    }
    r1 = db_query(q);
    //PDBG(sprintf("get_ideen_diskussion: %s => %Q",q,r1));
    if (query_db_error()) 
        return 0;
    if (options[UI_OPT_COUNTALL])
    {
        return get_one_int(r1);
    }
    r2 = ({ });
    foreach( mixed line : r1) // i.i_id, d.d_id, i.titel, d.pantheon
    {
        if (line[1] > 0)
        {
            r2 += ({ ({ "Diskussion", line[0], 
                         (line[3]?"Pantheon":"Spieler")
                         +(ist_diskussion_ungelesen(line[1], TP_RN)?
                            " ungelesen":""),
                         line[1] }) });
                                          // U,i_id,p/s,d_id
        }
    }
    //PDBG(sprintf("get_ideen_diskussion: ===> %Q",r2));
    return r2;
}

mixed get_ideen_wahl(mapping options)
{
    mixed * r1, *r2;
    string q;
    int last_i_id,i_id, u_id, i, *st_arr;
    if (!check_security())
    {
        return 0;
    }
    options ||= ([]);
    if (options[UI_OPT_COUNTALL])
    {
        q = "SELECT COUNT(*) ";
    }
    else
    {
        q = "SELECT i.i_id, u.u_id, i.titel, u.frage ";
    }
    q+= "FROM ideen i LEFT JOIN umfragen u ";
    if (intp(i_id = options[UI_OPT_I_ID]) && i_id > 0)
    {
        if (options[UI_OPT_PANTHEON] == 0)
        {
            q+= "ON (u.i_id = i.i_id AND u.pantheon = 0) ";
            q+= "WHERE i.i_id = "+i_id+" ";
        }
        else
        {
            q+= "WHERE u.i_id = i.i_id "; 
            q+= "AND i.i_id = "+i_id+" ";
        }
    }
    else if (intp(u_id = options[UI_OPT_U_ID]) && u_id > 0)
    {
        q+= "WHERE u.i_id = i.i_id "; 
        q+= "AND u.u_id = "+u_id+" ";
        if (options[UI_OPT_PANTHEON] == 0)
        {
            q+= "AND u.pantheon = 0 AND i.pantheon = 0 ";
        }
    }
    else
    {
        return 0; // Falscher Aufruf...
    }
    if (pointerp(options[UI_OPT_STATUS]) 
        && sizeof(st_arr =options[UI_OPT_STATUS]) )
    {
        q+= "AND i.status IN (";
         for (i=0; i< sizeof(st_arr); i++)
         {
            if (i>0) q+=",";
            q+=st_arr[i];
         }
         q+= ") ";
    }
    if (pointerp(options[UI_OPT_STATUS]) 
        && sizeof(st_arr =options[UI_OPT_STATUS]) )
    {
        q+= "AND u.status IN (";
         for (i=0; i< sizeof(st_arr); i++)
         {
            if (i>0) q+=",";
            q+=st_arr[i];
         }
         q+= ") ";
    }
    if (stringp(options[UI_OPT_SUCHFILTER]))
    {
        q+= "AND (i.titel LIKE '%"+options[UI_OPT_SUCHFILTER]+"%' ";
        q+= "OR i.inhalt LIKE '%"+options[UI_OPT_SUCHFILTER]+"%') ";
    }
    if (stringp(options[UI_OPT_ERSTELLER]))
    {
        q+= "AND (u.ersteller = '"+options[UI_OPT_ERSTELLER];
        q+= "' OR i.ersteller = '"+options[UI_OPT_ERSTELLER]+"') ";
    }
    if (!options[UI_OPT_COUNTALL])
    {
        // sortieren nach erhebung, titel,
        q+= "ORDER BY u.i_id, u.u_id ";
        if (options[UI_OPT_LIMIT] > 0)
        {
            q+= "LIMIT "+options[UI_OPT_LIMIT]+" ";
        }
        if (options[UI_OPT_OFFSET] > 0)
        {
            q+= "OFFSET "+options[UI_OPT_OFFSET]+" ";
        }
    }
    r1 = db_query(q);
    //PDBG(sprintf("get_ideen_wahl: %s => %Q",q,r1));
    if (query_db_error()) 
        return 0;
    if (options[UI_OPT_COUNTALL])
    {
        r2 = get_ideen_diskussion(options);
        return get_one_int(r1) + pointerp(r2) ? sizeof(r2) : 0;
    }
    r2 = ({ });
    last_i_id = 0;
    foreach( mixed line : r1) // u.i_id, u.u_id, i.titel, u.frage
    {
        if (last_i_id != line[0])
        {
            last_i_id = line[0];
            r2 += ({ ({ "Idee", line[0], line[2], 0 }) });  // I,i_id,titel,0
        }
        if (line[1] > 0)
        {
            r2 += ({ ({ "Umfrage", line[0], line[3], line[1] }) });
                                                          // U,i_id,frage,u_id
        }
    }
    r1 = get_ideen_diskussion(options);
    if (pointerp(r1)&&sizeof(r1))
    {
        r2 += r1;
    }
    //PDBG(sprintf("get_ideen_wahl: ===> %Q",r2));
    return r2;
}

int toggle_ignore_idee(int i_id, string wer)
{
    mixed * r1;
    string q;
    if (!check_security())
    {
        return 0;
    }
    q = "SELECT COUNT(*) FROM userignore ";
    q+= "WHERE wer = ? AND id = ? AND was ='ideen' ";
    r1 = db_query(q,wer,i_id);
    if (get_one_int(r1)>0)
    {
        q = "DELETE FROM userignore WHERE wer = ? AND id = ? ";
        q+= "AND was = 'ideen' ";
        db_query(q,wer,i_id);
        return -1;
    }
    else
    {
        q = "INSERT INTO userignore (wer,was,id) VALUES (?,'ideen',?) ";
        db_query(q,wer,i_id);
        return 1;
    }
}

private string get_ideen_wahl_query(mapping options, string prefix)
{
    string q;
    int i, *st_arr;
    q = prefix;
    if (stringp(options[UI_OPT_ERSTELLER]))
    {
        q+= "AND i.ersteller = '"+options[UI_OPT_ERSTELLER]+"' ";
    }
    else if (options[UI_OPT_PANTHEON] == 0)
    {
        q+= "AND i.pantheon = 0 ";
    }
    if (options[UI_OPT_OHNE_DISKUSSION] == 1)
    {
        q+= "AND i.i_id NOT IN (SELECT DISTINCT id FROM diskussion ";
        q+= "WHERE was = 'ideen') ";
    }
    else if (options[UI_OPT_DISKUSSION] == 1)
    {
        q+= "AND i.i_id IN (SELECT DISTINCT id FROM diskussion ";
        q+= "WHERE was = 'ideen') ";
    }
    if (options[UI_OPT_IGNORELIST] == 0)
    {
        q+= "AND i.i_id NOT IN (SELECT DISTINCT id FROM userignore ";
        q+= "WHERE was = 'ideen' AND wer = '"+TP_RN+"') ";        
    }
    else if (options[UI_OPT_IGNORELIST] == 2)
    {
        q+= "AND i.i_id IN (SELECT DISTINCT id FROM userignore ";
        q+= "WHERE was = 'ideen' AND wer = '"+TP_RN+"') ";        
    }
    if (options[UI_OPT_UMFRAGE_OFFEN] == 1)
    {
        q+= "AND i.i_id IN (SELECT i_id FROM umfragen ";
        q+= "WHERE u_id NOT IN (SELECT U_ID FROM erhebung ";
        q+= "WHERE wer = '"+TP_RN+"')) ";
    }
    if (stringp(options[UI_OPT_SUCHFILTER]))
    {
        q+= "AND (i.titel LIKE '%"+options[UI_OPT_SUCHFILTER]+"%' ";
        q+= "OR i.inhalt LIKE '%"+options[UI_OPT_SUCHFILTER]+"%') ";
    }
    if (pointerp(options[UI_OPT_STATUS]) 
        && sizeof(st_arr =options[UI_OPT_STATUS]) )
    {
        q+= "AND i.status IN (";
         for (i=0; i< sizeof(st_arr); i++)
         {
            if (i>0) q+=",";
            q+=st_arr[i];
         }
         q+= ") ";
    }
    if (stringp(options[UI_OPT_I_ID]))
    {
        q+= "AND i.i_id = "+options[UI_OPT_I_ID]+" ";
    }
    return q;
}

mixed get_ideen_wahl_uebersicht(mapping options)
{
    mixed * r1;
    string q;
    if (!check_security())
    {
        return 0;
    }
    options ||= ([]);
    if (options[UI_OPT_COUNTALL])
    {
        q = "SELECT COUNT(*) ";
    }
    else
    {
        q = "SELECT i.i_id, i.titel ";
    }
    q+= "FROM ideen i ";
    q+= "WHERE 1 ";
    q = get_ideen_wahl_query(options, q);
    if (!options[UI_OPT_COUNTALL])
    {
        // sortieren nach erhebung, titel,
        q+= "ORDER BY i.i_id ";
        if (options[UI_OPT_LIMIT] > 0)
        {
            q+= "LIMIT "+options[UI_OPT_LIMIT]+" ";
        }
        if (options[UI_OPT_OFFSET] > 0)
        {
            q+= "OFFSET "+options[UI_OPT_OFFSET]+" ";
        }
    }
    r1 = db_query(q);
    //PDBG(sprintf("get_ideen_wahl_uebersicht: %s => %Q",q,r1));
    if (query_db_error()) 
        return 0;
    if (options[UI_OPT_COUNTALL])
    {
        return get_one_int(r1);
    }
    
    return r1;
}

