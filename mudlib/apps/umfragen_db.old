    string q;
    mixed r1;
    if (!check_security())
    {
        return 0;
    }
    if (options[UI_OPT_COUNTALL])
    {
        q = "SELECT COUNT(*) ";
    }
    else
    {
#define X_FRAGEN_COLUMNS ({ \
    UI_OPT_XF_ID,UI_OPT_XT_ID,UI_OPT_UNIFIED_ID, \
    UI_OPT_FRAGE,UI_OPT_DESCRIPTION,UI_OPT_ANZ_ANTWORTEN, \
    UI_OPT_FRAGEN_TYP,UI_OPT_SEQUENCE })

        q = "SELECT xf_id,xt_id,unified_id, "
            "frage,description,anzahl_antworten,fragen_typ,seq ";
    }
    q+= "FROM xfragen ";
    q+= "WHERE 1=1 ";
    if (options[UI_OPT_XF_ID]>0)
    {
        q+= "AND xf_id = "+options[UI_OPT_XF_ID]+" ";
    }
    if (options[UI_OPT_XT_ID]>0)
    {
        q+= "AND xt_id = "+options[UI_OPT_XT_ID]+" ";
    }
    if (!options[UI_OPT_COUNTALL])
    {
        q+= "ORDER BY seq,xf_id ";
        if (options[UI_OPT_LIMIT] > 0)
        {
            q+= "LIMIT "+options[UI_OPT_LIMIT]+" ";
        }
        if (options[UI_OPT_OFFSET] > 0)
        {
            q+= "OFFSET "+options[UI_OPT_OFFSET]+" ";
        }
    }
    r1 = db_query(q);
    if (query_db_error()) 
        return 0;
    if (options[UI_OPT_COUNTALL])
    {
        return get_one_int(r1);
    }
    return r1;
}

int create_x_frage(int xt_id)
{
    if (!check_security())
    {
        return 0;
    }
    mapping thema = get_x_thema(xt_id);
    if (!mappingp(thema)) // TODO Status pruefen?
    {
        return 0;
    }
    int xf_id = increment_counter("xf_id");
    int seq = 1;
    if (xf_id <= 0) 
        return 0;
    mixed r2 = db_query_err("SELECT MAX(seq) FROM xfragen "
        "WHERE xt_id = ? ",xt_id);
    if (sizeof(r2)==1)
    {
        seq = get_one_int(r2)+1;
    }
    db_query("INSERT INTO xfragen "
        "(xf_id, xt_id,seq) "
        "VALUES (?,?,?)",xf_id,xt_id,seq);
    if (query_db_error()) 
        return 0;
    return xf_id; 
}

mapping get_x_frage(int xf_id)
{
    if (!check_security())
    {
        return 0;
    }
    mixed *r1 = get_xfragen(([UI_OPT_XF_ID:xf_id]) );
    if (!sizeof(r1))
        return 0;
    return mkmapping(X_FRAGEN_COLUMNS,r1[0]); 
}

int set_x_frage(mapping newdata)
{
    if (!check_security())
    {
        return 0;
    }
    if (!mappingp(newdata)) 
    {
        return 0;
    }
    int xf_id = newdata[UI_OPT_XF_ID];
    mapping olddata = get_x_frage(xf_id);
    if (!mappingp(olddata)) 
    {
        return 0;
    }
    string q = "";
    if (member(newdata,UI_OPT_UNIFIED_ID)
        && stringp(newdata[UI_OPT_UNIFIED_ID]) &&
        newdata[UI_OPT_UNIFIED_ID] != olddata[UI_OPT_UNIFIED_ID])
    {
        if (q != "")
            q+= ", ";
        q+= "unified_id = '"
           +db_escape_string(newdata[UI_OPT_UNIFIED_ID])
           +"' ";
    }
    if (member(newdata,UI_OPT_FRAGE)
        && stringp(newdata[UI_OPT_FRAGE]) &&
        newdata[UI_OPT_FRAGE] != olddata[UI_OPT_FRAGE])
    {
        if (q != "")
            q+= ", ";
        q+= "frage = '"
           +db_escape_string(newdata[UI_OPT_FRAGE])
           +"' ";
    }
    if (member(newdata,UI_OPT_DESCRIPTION)
        && stringp(newdata[UI_OPT_DESCRIPTION]) &&
        newdata[UI_OPT_DESCRIPTION] != olddata[UI_OPT_DESCRIPTION])
    {
        if (q != "")
            q+= ", ";
        q+= "description = '"
           +db_escape_string(newdata[UI_OPT_DESCRIPTION])
           +"' ";
    }
    if (member(newdata,UI_OPT_ANZ_ANTWORTEN)
        && intp(newdata[UI_OPT_ANZ_ANTWORTEN]) &&
        newdata[UI_OPT_ANZ_ANTWORTEN] != olddata[UI_OPT_ANZ_ANTWORTEN])
    {
        if (q != "")
            q+= ", ";
        q+= "anzahl_antworten = "+newdata[UI_OPT_ANZ_ANTWORTEN]+" ";
    }
    if (member(newdata,UI_OPT_FRAGEN_TYP)
        && intp(newdata[UI_OPT_FRAGEN_TYP]) &&
        newdata[UI_OPT_FRAGEN_TYP] != olddata[UI_OPT_FRAGEN_TYP])
    {
        if (q != "")
            q+= ", ";
        q+= "fragen_typ = "+newdata[UI_OPT_FRAGEN_TYP]+" ";
    }
    if (q == "")
    {
        return 1;
    }
    q = "UPDATE xfragen SET "+q+"WHERE xf_id = ?";
    db_query(q,xf_id);
    if (query_db_error())
        return 0;
    return 1;
}

int change_xfrage_seq(int xf_id,int plusminus)
{
    if (!check_security())
    {
        return 0;
    }
    mapping frage1 = get_x_frage(xf_id);
    if (!mappingp(frage1))
    {
        return 0; // Fehler.
    }
    int x_seq = frage1[UI_OPT_SEQUENCE];
    mixed r2;
    if (plusminus == 1)
    {
        r2 = db_query_err("SELECT xf_id,seq FROM xfragen "
            "WHERE xt_id = ?1 AND seq > ?2 ORDER BY seq,xf_id "
            "LIMIT 1",
            frage1[UI_OPT_XT_ID],x_seq);
    }
    else if (plusminus == -1)
    {
        r2 = db_query_err("SELECT xf_id,seq FROM xfragen "
            "WHERE xt_id = ?1 AND seq < ?2 ORDER BY seq DESC,xf_id DESC "
            "LIMIT 1",
            frage1[UI_OPT_XT_ID],x_seq);
    }
    else
    {
        return 0; // fehler.
    }
    if (sizeof(r2)!=1)
    {
        return 2; // grenze erreicht.
    }
    r2 = r2[0];
    db_begin();
    db_query_err("UPDATE xfragen SET seq = ?2 "
        "WHERE xf_id = ?1 ", xf_id,r2[1]);
    db_query_err("UPDATE xfragen SET seq = ?2 "
        "WHERE xf_id = ?1 ", r2[0],x_seq);
    db_commit();
    return 1;
}

// -------------------------------------------------------------------------

<mixed*|int> get_xantworten(mapping options)
{
    string q;
    mixed r1;
    if (!check_security())
    {
        return 0;
    }
    if (options[UI_OPT_COUNTALL])
    {
        q = "SELECT COUNT(*) ";
    }
    else
    {
#define X_ANTWORTEN_COLUMNS ({ \
    UI_OPT_XA_ID,UI_OPT_XF_ID,UI_OPT_UNIFIED_ID, \
    UI_OPT_ANTWORT,UI_OPT_SEQUENCE })

        q = "SELECT xa_id,xf_id,unified_id, "
            "antwort,seq ";
    }
    q+= "FROM xantworten ";
    q+= "WHERE 1=1 ";
    if (options[UI_OPT_XA_ID]>0)
    {
        q+= "AND xa_id = "+options[UI_OPT_XA_ID]+" ";
    }
    if (options[UI_OPT_XF_ID]>0)
    {
        q+= "AND xf_id = "+options[UI_OPT_XF_ID]+" ";
    }
    if (!options[UI_OPT_COUNTALL])
    {
        q+= "ORDER BY seq,xa_id ";
        if (options[UI_OPT_LIMIT] > 0)
        {
            q+= "LIMIT "+options[UI_OPT_LIMIT]+" ";
        }
        if (options[UI_OPT_OFFSET] > 0)
        {
            q+= "OFFSET "+options[UI_OPT_OFFSET]+" ";
        }
    }
    r1 = db_query(q);
    if (query_db_error()) 
        return 0;
    if (options[UI_OPT_COUNTALL])
    {
        return get_one_int(r1);
    }
    if (options[UI_OPT_MAPPING])
    {
        return map(r1,(: mkmapping(X_ANTWORTEN_COLUMNS,$1) :) );
    }
    return r1;
}

int create_x_antwort(int xf_id)
{
    if (!check_security())
    {
        return 0;
    }
    mapping frage = get_x_frage(xf_id);
    if (!mappingp(frage)) // TODO Status pruefen?
    {
        return 0;
    }
    int xa_id = increment_counter("xa_id");
    int seq = 1;
    if (xa_id <= 0) 
        return 0;
    mixed r2 = db_query_err("SELECT MAX(seq) FROM xantworten "
        "WHERE xf_id = ? ",xf_id);
    if (sizeof(r2)==1)
    {
        seq = get_one_int(r2)+1;
    }
    db_query("INSERT INTO xantworten "
        "(xa_id,xf_id, seq) "
        "VALUES (?,?,?)",xa_id,xf_id,seq);
    if (query_db_error()) 
        return 0;
    return xa_id; 
}

mapping get_x_antwort(int xa_id)
{
    if (!check_security())
    {
        return 0;
    }
    mixed *r1 = get_xantworten(([UI_OPT_XA_ID:xa_id]) );
