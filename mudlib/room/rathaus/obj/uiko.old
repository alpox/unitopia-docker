        browse_write_line("Vorherige Eingabe: "+val);
}

private void inp_frage_zeit3_3_10(string str,string uidp,string val,
    mapping l_options,mapping *l_data)
{
    if (str == "q" || str == "~q")
    {
        browse_write_line("Eingabe abgebrochen.");
        return;
    }
    int ausw = to_int(space(str));
    if (ausw < 1 || ausw > 4)
    {
        list_zeit3_3_10(val);
        input_to(#'inp_frage_zeit3_3_10,INPUT_PROMPT,
            "Eine Antwort 1 bis 4 wählen: ",uidp,val,l_options,l_data);
        return;
    }
    get_master()->set_x_auswertung(
        uidp,
        l_options[UI_OPT_USER_NAME],
        to_string(ausw),
        l_options[UI_OPT_USER_TYPE],
        l_options[UI_OPT_GILDE]
    );
    loop_x_umfrage(l_options,l_data);
}

