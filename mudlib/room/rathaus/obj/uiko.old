#define HELP_x_themen_liste ({ \
"In dieser Ansicht werden die Themen einer Umfrage gelistet.",\
})

static mixed x_themen_liste_init(mapping old)
{
    old[B_START_LINE] = 0;
    old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                     B_PROMPT : "Hilfe zu den Themen einer Umfrage Zeile",
                     B_DATA : HELP_x_themen_liste+HELP_standard ]);
    old[B_NUM_LINES] -= sizeof(old[UI_OPT_DESCRIPTION]||({}));
    return old;
}

static int x_themen_liste_total(mapping menue)
{
    return get_master()->get_xthemen(menue+([UI_OPT_COUNTALL:1]) );
}

static string * x_themen_liste_display(mapping menue)
{
    string * lines = ({});
    mixed *xlines = get_master()->get_xthemen(menue
        +([UI_OPT_LIMIT:  menue[B_NUM_LINES],
           UI_OPT_OFFSET: menue[B_CURRENT_LINE] ]) );
    if (xlines == 0 || sizeof(xlines) <= 0) 
        return ({"Keine Themen zur Auswahl!"});
    mapping cache = ([]);
    int i;
    for (i=0;i<sizeof(xlines);i++)
    {
        int ix = i+menue[B_CURRENT_LINE]+1;
        cache[ix] = xlines[i][0]; // id
        lines += ({ sprintf("%02d %s",
            ix,xlines[i][3]||"") }); // title
    }
    menue[UI_OPT_CACHE] = cache;
    return lines;
}

static string x_themen_liste_prompt(mapping menue)
{
    return sprintf("Themen (%d,%d) [<nr>,q,z,?]",
        menue[B_CURRENT_LINE]+1,menue[B_END_LINE]);
}

static mixed x_themen_liste_action(string str, mapping * menues)
{
    string * split = explode(space(str)," ");
    mapping menue = menues[<1];
    mapping cache = menue[UI_OPT_CACHE]||([]);
    int ix = to_int(split[<1]);
    if (sizeof(split)==1 && ix > 0)
    {
        if (member(cache,ix))
        {
            return menues + ({([
                B_TYPE : "x_fragen_liste",
                UI_OPT_XT_ID : cache[ix],
            ])});
        }
        else
        {
            browse_write_line("Nummer passt nicht zur Anzeige.");
            return B_DONE;
        }
    }
    switch(split[0])
    {
        case "n": // neu
            if (!query_commander(TP))
            {
                browse_write_line("Keine Berechtigung zur Neuanlage.");
                return B_DONE;
            }
            ix = get_master()->create_x_thema(TP,menue[UI_OPT_XU_ID]);
            if (ix <= 0)
            {
                browse_write_line("Fehler beim Erstellen.");
                return B_DONE;
            }
            return menues + ({([
                B_TYPE : "x_thema_admin",
                UI_OPT_XT_ID : ix,
            ])});
        case "e": // editiere <nr>
            if (!query_commander(TP))
            {
                browse_write_line("Keine Berechtigung zum Editieren.");
                return B_DONE;
            }
            if (ix <= 0)
            {
                browse_write_line("Syntax: e <nr>");;
                return B_DONE;
            }
            if (!member(cache,ix))
            {
                browse_write_line("Nummer passt nicht zur Anzeige.");
            }
            return menues + ({([
                B_TYPE : "x_thema_admin",
                UI_OPT_XT_ID : cache[ix],
            ])});
        case "up":
            if (!query_commander(TP))
            {
                browse_write_line("Keine Berechtigung für die Sequenz.");
                return B_DONE;
            }
            if (!member(cache,ix))
            {
                browse_write_line("Ungültiges Element bei up <nr>");
                return B_DONE;
            }
            switch (get_master()->change_xthema_seq(cache[ix],-1))
            {
                default:
                case 0:
                    browse_write_line("Interner Fehler Sequenzänderung.");
                    return B_DONE;
                case 1:
                    browse_write_line("Sequenz geändert.");
                    return B_REBUILT;
                case 2:
                    browse_write_line("Anfang erreicht.");
                    return B_DONE;
            }
        case "down":
            if (!query_commander(TP))
            {
                browse_write_line("Keine Berechtigung für die Sequenz.");
                return B_DONE;
            }
            if (!member(cache,ix))
            {
                browse_write_line("Ungültiges Element bei down <nr>");
                return B_DONE;
            }
            switch (get_master()->change_xthema_seq(cache[ix],1))
            {
                default:
                case 0:
                    browse_write_line("Interner Fehler Sequenzänderung.");
                    return B_DONE;
                case 1:
                    browse_write_line("Sequenz geändert.");
                    return B_REBUILT;
                case 2:
                    browse_write_line("Ende erreicht.");
                    return B_DONE;
            }
    }
}

