#define HELP_beitrag ({ \
"In dieser Ansicht ist ein Beitrag zu sehen.",\
})

static mixed beitrag_init(mapping old)
{
    old[B_DATA] = get_master()->get_beitrag(old[UI_OPT_B_ID])
        +({"------------ Ende Beitrag ----------------"});
    old[B_START_LINE] = 0;
    old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                     B_PROMPT : "Hilfe zu Beitragsansicht Zeile",
                     B_DATA : HELP_beitrag+HELP_standard ]);
    master->update_gelesen(old, TP_RN);
    return old;
}

static string * beitrag_display(mapping menue)
{
    return staticmore_display(menue);
}

static int beitrag_total(mapping menue)
{
    return sizeof(menue[B_DATA]);
}

static string beitrag_prompt(mapping menue)
{
    return sprintf("Diskussionsbeitrag Zeile %d/%d [z,q,?]",
        menue[B_CURRENT_LINE],sizeof(menue[B_DATA]) );
}

static mixed beitrag_action(string str, mapping * menues)
{
    mapping menue = menues[<1];
    switch (lower_case(space(str)))
    {
    case "gelesen":
        get_master()->update_gelesen(menue, TP_RN);
        return B_REBUILT;
    case "ungelesen":
        get_master()->update_ungelesen(menue, TP_RN);
        return B_REBUILT;
    }
    return B_NOTHING;
}

//---------------------------------------------------------------------------
#define HELP_x_umfragen_wahl ({ \
"In dieser Ansicht sind Umfragen zur Wahl zu sehen.",\
})
static mixed x_umfragen_wahl_init(mapping old)
{
    old[B_START_LINE] = 0;
    old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                     B_PROMPT : "Hilfe zu Umfragen Wahl Zeile",
                     B_DATA : HELP_x_umfragen_wahl+HELP_standard ]);
    return old;
}

static int x_umfragen_wahl_total(mapping menue)
{
    return get_master()->get_xumfragen(TP,menue
        +([UI_OPT_COUNTALL:1]) );
}

static string * x_umfragen_wahl_display(mapping menue)
{
    mixed * xlines = get_master()->get_xumfragen(TP,menue
        +([UI_OPT_LIMIT:  menue[B_NUM_LINES],
           UI_OPT_OFFSET: menue[B_CURRENT_LINE] ]) );
    if (xlines == 0 || sizeof(xlines) <= 0) 
        return ({"Keine Umfragen zur Auswahl!"});
    string * lines = ({});
    mapping cache = ([]);
    int i;
    for (i=0;i<sizeof(xlines);i++)
    {
        int ix = i+menue[B_CURRENT_LINE]+1;
        cache[ix] = xlines[i][0]; // id
        lines += ({ sprintf("%02d %s",
            ix,xlines[i][2]||"") }); // title
    }
    menue[UI_OPT_CACHE] = cache;
    return lines;
}

static string x_umfragen_wahl_prompt(mapping menue)
{
    return sprintf("Offene Umfragen %d,%d [<nr>,q,z,?]",
        menue[B_CURRENT_LINE]+1,menue[B_END_LINE]);
}

static mixed x_umfragen_wahl_action(string str, mapping * menues)
{
    string * split = explode(space(str)," ");
    mapping options = menues[<1];
    mapping cache = options[UI_OPT_CACHE]||([]);
    int ix = to_int(split[<1]);
    if (sizeof(split)==1 && ix > 0)
    {
        if (member(cache,ix))
        {
            browse_write_line("Wahlmodus derzeit nicht unterstützt.");
            return B_DONE;
        }
        else
        {
            browse_write_line("Nummer passt nicht zur Anzeige.");
            return B_DONE;
        }
    }
    switch(split[0])
    {
        case "n": // neu
            if (!query_commander(TP))
            {
                browse_write_line("Keine Berechtigung zur Neuanlage.");
                return B_DONE;
            }
            ix = get_master()->create_x_umfrage();
            if (ix <= 0)
            {
                browse_write_line("Fehler beim Erstellen.");
                return B_DONE;
            }
            return menues + ({([
                B_TYPE : "x_umfrage_admin",
                UI_OPT_XU_ID : ix,
            ])});
        case "e": // editiere <nr>
            if (!query_commander(TP))
            {
                browse_write_line("Keine Berechtigung zum Editieren.");
                return B_DONE;
            }
            if (ix <= 0)
            {
                browse_write_line("Syntax: e <nr>");;
                return B_DONE;
            }
            if (!member(cache,ix))
            {
                browse_write_line("Nummer passt nicht zur Anzeige.");
            }
            return menues + ({([
                B_TYPE : "x_umfrage_admin",
                UI_OPT_XU_ID : cache[ix],
            ])});
    }
    return B_NOTHING;
}

//---------------------------------------------------------------------------
#define HELP_x_umfrage_admin ({ \
"In dieser Ansicht wird eine Umfrage editiert.",\
})
private string* get_x_umfrage(mapping options)
{
    string * lines = ({});
    mapping m_umf = get_master()->get_x_umfrage(TP,options[UI_OPT_XU_ID]);
    if (!mappingp(m_umf))
    {
        return ({"Keine Anzeige."});
    }
    lines+=({"Umfragen-ID: "+m_umf[UI_OPT_XU_ID]
             +" (i)Unified-ID: "+m_umf[UI_OPT_UNIFIED_ID]});
    lines+=({"(t) Titel: "+m_umf[UI_OPT_TITLE],"(b) Beschreibung:"});
    lines+=explode(wrap(m_umf[UI_OPT_DESCRIPTION]||""),"\n")[..<2];
    lines+=explode(wrap_say("(ut) User-Type: ",
        get_master()->resolve_user_status(m_umf[UI_OPT_USER_TYPE])),
        "\n")[..<2];
    lines+=({"(s) Status: "+get_status(m_umf[UI_OPT_STATUS])});
    lines+=({"(l) Liste der Themen"});
    return lines;
}
static mixed x_umfrage_admin_init(mapping old)
{
    old[B_START_LINE] = 0;
    old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                     B_PROMPT : "Hilfe zum Editieren der Umfrage Zeile",
                     B_DATA : HELP_x_umfrage_admin+HELP_standard ]);
    return old;
}

static int x_umfrage_admin_total(mapping menue)
{
    return sizeof(get_x_umfrage(menue));
}

static string * x_umfrage_admin_display(mapping menue)
{
    menue[B_DATA] = get_x_umfrage(menue);
    return staticmore_display(menue);
}

static string x_umfrage_admin_prompt(mapping menue)
{
    return sprintf("Umfrage %d %d/%d [i,t,b,ut,s,z,q]",
        menue[UI_OPT_XU_ID],menue[B_CURRENT_LINE],menue[B_END_LINE]);
}

static mixed x_umfrage_admin_action(string str, mapping * menues)
{
    string * split = explode(space(str)," ");
    string param = implode(split[1..]," ");
    mapping menue = menues[<1];
    mapping opt = ([UI_OPT_XU_ID:menue[UI_OPT_XU_ID] ]);
    if (!query_commander(TP) || TI!=TP) 
    {
        browse_write_line("Kein Zugriff!");
        return B_QUIT;
    }
    switch (split[0])
    {
        case "l":
            return menues + ({([
                B_TYPE : "x_themen_liste",
                UI_OPT_XU_ID : menue[UI_OPT_XU_ID],
            ])});
        case "i": // i <unified-id>
            if (sizeof(split)==2 || param=="")
            {
                opt[UI_OPT_UNIFIED_ID] = param;
                if (get_master()->set_x_umfrage(TP,opt))
                {
                    browse_write_line("unified-id gesetzt.");
                    return B_REBUILT;
                }
                else
                {
                    browse_write_line("Fehler beim Speichern.");
                    return B_DONE;
                }
            }
            else
            {
                browse_write_line("Syntax: i <unified-id>");
                browse_write_line(
                    "Wobei die ID keine Leerzeichen enthalten darf.");
                return B_DONE;
            }
        case "t": // t <titel>
            opt[UI_OPT_TITLE] = param;
            if (get_master()->set_x_umfrage(TP,opt))
            {
                browse_write_line("Titel gesetzt.");
                return B_REBUILT;
            }
            else
            {
                browse_write_line("Fehler beim Speichern.");
                return B_DONE;
            }
        case "b": // b <beschreibung> bzw b -> editor?
            opt[UI_OPT_DESCRIPTION] = param;
            if (get_master()->set_x_umfrage(TP,opt))
            {
                browse_write_line("Beschreibung gesetzt.");
                return B_REBUILT;
            }
            else
            {
                browse_write_line("Fehler beim Speichern.");
                return B_DONE;
            }
        case "ut": // ut+/ut- <utype>
            browse_write_line(
                "Entweder ut+ oder ut- mit einem der folgenden Parameter:");
            browse_write_line(get_master()->resolve_user_status(
                UI_USER_TYPE_ALL));
            return B_DONE;
        case "ut+":
            if (param == "")
            {
                browse_write_line(
                    "ut+ <parameter> mit einem der folgenden Parameter:");
                browse_write_line(get_master()->resolve_user_status(
                    UI_USER_TYPE_ALL));
                return B_DONE;
            }
            int new_ut = get_master()->user_status2value(param);
            if (new_ut == 0)
            {
                browse_write_line(
                    "ut+ <parameter> mit einem der folgenden Parameter:");
                browse_write_line(get_master()->resolve_user_status(
                    UI_USER_TYPE_ALL));
                return B_DONE;
            }
            opt = get_master()->get_x_umfrage(TP,menue[UI_OPT_XU_ID]);
            if ( (opt[UI_OPT_USER_TYPE]&new_ut)==new_ut)
            {
                browse_write_line("User Type(s) schon gesetzt.");
                return B_DONE;
            }
            opt[UI_OPT_USER_TYPE]|=new_ut;
            if (get_master()->set_x_umfrage(TP,opt))
            {
                browse_write_line("User Type(s) gesetzt.");
                return B_REBUILT;
            }
            else
            {
                browse_write_line("Fehler beim Speichern.");
                return B_DONE;
            }
        case "ut-":
            if (param == "")
            {
                browse_write_line(
                    "ut- <parameter> mit einem der folgenden Parameter:");
                browse_write_line(get_master()->resolve_user_status(
                    UI_USER_TYPE_ALL));
                return B_DONE;
            }
            int new_ut = get_master()->user_status2value(param);
            if (new_ut == 0)
            {
                browse_write_line(
                    "ut- <parameter> mit einem der folgenden Parameter:");
                browse_write_line(get_master()->resolve_user_status(
                    UI_USER_TYPE_ALL));
                return B_DONE;
            }
            opt = get_master()->get_x_umfrage(TP,menue[UI_OPT_XU_ID]);
            new_ut = opt[UI_OPT_USER_TYPE] & (UI_USER_TYPE_ALL ^ new_ut);
            if (new_ut == opt[UI_OPT_USER_TYPE])
            {
                browse_write_line("User Type(s) schon gelöscht.");
                return B_DONE;
            }
            opt[UI_OPT_USER_TYPE] = new_ut;
            if (get_master()->set_x_umfrage(TP,opt))
            {
                browse_write_line("User Type(s) gelöscht.");
                return B_REBUILT;
            }
            else
            {
                browse_write_line("Fehler beim Speichern.");
                return B_DONE;
            }
        case "s": // s <status>
            opt = get_master()->get_x_umfrage(TP,menue[UI_OPT_XU_ID]);
            return menues + ({([
                B_TYPE : "status_wahl",
                UI_OPT_STATUS: opt[UI_OPT_STATUS],
                UI_OPT_XU_ID: menue[UI_OPT_XU_ID]
            ])});
    }
    return B_NOTHING;
}

