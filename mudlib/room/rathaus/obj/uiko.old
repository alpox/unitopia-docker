                     B_PROMPT : "Hilfe zu Fragen Liste Zeile",
                     B_DATA : HELP_x_fragen_liste+HELP_standard ]);
    return old;
}

static int x_fragen_liste_total(mapping menue)
{
    return get_master()->get_xfragen(menue
        +([UI_OPT_COUNTALL:1]) );
}

static string * x_fragen_liste_display(mapping menue)
{
    mixed * xlines = get_master()->get_xfragen(menue
        +([UI_OPT_LIMIT:  menue[B_NUM_LINES],
           UI_OPT_OFFSET: menue[B_CURRENT_LINE] ]) );
    if (xlines == 0 || sizeof(xlines) <= 0) 
        return ({"Keine Fragen zur Auswahl!"});
    string * lines = ({});
    mapping cache = ([]);
    int i;
    for (i=0;i<sizeof(xlines);i++)
    {
        int ix = i+menue[B_CURRENT_LINE]+1;
        cache[ix] = xlines[i][0]; // id
        lines += ({ sprintf("%02d %s",
            ix,xlines[i][3]||"") }); // frage
    }
    menue[UI_OPT_CACHE] = cache;
    return lines;
}

static string x_fragen_liste_prompt(mapping menue)
{
    return sprintf("Fragen %d,%d [<nr>,q,z,?]",
        menue[B_CURRENT_LINE]+1,menue[B_END_LINE]);
}

static mixed x_fragen_liste_action(string str, mapping * menues)
{
    string * split = explode(space(str)," ");
    mapping menue = menues[<1];
    mapping cache = menue[UI_OPT_CACHE]||([]);
    int ix = to_int(split[<1]);
    if (sizeof(split)==1 && ix > 0)
    {
        if (member(cache,ix))
        {
            return menues + ({([
                B_TYPE : "x_frage_admin",
                UI_OPT_XF_ID : cache[ix],
            ])});
        }
        else
        {
            browse_write_line("Nummer passt nicht zur Anzeige.");
            return B_DONE;
        }
    }
    switch(split[0])
    {
        case "n": // neu
            if (!query_commander(TP))
            {
                browse_write_line("Keine Berechtigung zur Neuanlage.");
                return B_DONE;
            }
            ix = get_master()->create_x_frage(menue[UI_OPT_XT_ID]);
            if (ix <= 0)
            {
                browse_write_line("Fehler beim Erstellen.");
                return B_DONE;
            }
            return menues + ({([
                B_TYPE : "x_frage_admin",
                UI_OPT_XF_ID : ix,
            ])});   
        case "up":
            if (!query_commander(TP))
            {
                browse_write_line("Keine Berechtigung für die Sequenz.");
                return B_DONE;
            }
            if (!member(cache,ix))
            {
                browse_write_line("Ungültiges Element bei up <nr>");
                return B_DONE;
            }
            switch (get_master()->change_xfrage_seq(cache[ix],-1))
            {
                default:
                case 0:
                    browse_write_line("Interner Fehler Sequenzänderung.");
                    return B_DONE;
                case 1:
                    browse_write_line("Sequenz geändert.");
                    return B_REBUILT;
                case 2:
                    browse_write_line("Anfang erreicht.");
                    return B_DONE;
            }
        case "down":
            if (!query_commander(TP))
            {
                browse_write_line("Keine Berechtigung für die Sequenz.");
                return B_DONE;
            }
            if (!member(cache,ix))
            {
                browse_write_line("Ungültiges Element bei down <nr>");
                return B_DONE;
            }
            switch (get_master()->change_xfrage_seq(cache[ix],1))
            {
                default:
                case 0:
                    browse_write_line("Interner Fehler Sequenzänderung.");
                    return B_DONE;
                case 1:
                    browse_write_line("Sequenz geändert.");
                    return B_REBUILT;
                case 2:
                    browse_write_line("Ende erreicht.");
                    return B_DONE;
            }
    }
    return B_NOTHING;
}

//---------------------------------------------------------------------------
#define HELP_x_frage_admin ({ \
"In dieser Ansicht wird eine Frage editiert.",\
})

private string* get_x_frage(mapping options)
{
    string * lines = ({});
    mapping m_frage = get_master()->get_x_frage(options[UI_OPT_XF_ID]);
    if (!mappingp(m_frage))
    {
        return ({"Keine Anzeige."});
    }
    lines+=({"Fragen-ID: "+m_frage[UI_OPT_XF_ID]
             +" (i)Unified-ID: "+m_frage[UI_OPT_UNIFIED_ID]});
    lines+=({"Themen-ID: "+m_frage[UI_OPT_XT_ID]
             +" Sequenz: "+m_frage[UI_OPT_SEQUENCE]});
    lines+=({"(f) Frage: "+m_frage[UI_OPT_FRAGE],"(b) Beschreibung:"});
    lines+=explode(wrap(m_frage[UI_OPT_DESCRIPTION]||""),"\n")[..<2];
    lines+=({"(ft) Fragentyp: "
        +UI_FRAGEN_TYP_LISTE[m_frage[UI_OPT_FRAGEN_TYP]]});
    lines+=({"(aa) Anzahl Antworten: "+m_frage[UI_OPT_ANZ_ANTWORTEN]});
    lines+=({"(a) Antwortliste"});
    return lines;
}

static mixed x_frage_admin_init(mapping old)
{
    old[B_START_LINE] = 0;
    old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                     B_PROMPT : "Hilfe zum Editieren der Frage Zeile",
                     B_DATA : HELP_x_frage_admin+HELP_standard ]);
    return old;
}

static int x_frage_admin_total(mapping menue)
{
    return sizeof(get_x_frage(menue));
}

static string * x_frage_admin_display(mapping menue)
{
    menue[B_DATA] = get_x_frage(menue);
    return staticmore_display(menue);
}

static string x_frage_admin_prompt(mapping menue)
{
    return sprintf("Frage %d %d/%d [i,t,b,ut,s,z,q]",
        menue[UI_OPT_XF_ID],menue[B_CURRENT_LINE],menue[B_END_LINE]);
}

static mixed x_frage_admin_action(string str, mapping * menues)
{
    string * split = explode(space(str)," ");
    string param = implode(split[1..]," ");
    mapping menue = menues[<1];
    mapping opt = ([UI_OPT_XF_ID:menue[UI_OPT_XF_ID] ]);
    int ix;
    if (!query_commander(TP) || TI!=TP) 
    {
        browse_write_line("Kein Zugriff!");
        return B_QUIT;
    }
    switch (split[0])
    {
        case "i": // i <unified-id>
            if (sizeof(split)==2 || param=="")
            {
                opt[UI_OPT_UNIFIED_ID] = param;
                if (get_master()->set_x_frage(opt))
                {
                    browse_write_line("unified-id gesetzt.");
                    return B_REBUILT;
                }
                else
                {
                    browse_write_line("Fehler beim Speichern.");
                    return B_DONE;
                }
            }
            else
            {
                browse_write_line("Syntax: i <unified-id>");
                browse_write_line(
                    "Wobei die ID keine Leerzeichen enthalten darf.");
                return B_DONE;
            }
        case "f": // f <frage>
            opt[UI_OPT_FRAGE] = param;
            if (get_master()->set_x_frage(opt))
            {
                browse_write_line("Frage gesetzt.");
                return B_REBUILT;
            }
            else
            {
                browse_write_line("Fehler beim Speichern.");
                return B_DONE;
            }
        case "b": // b <beschreibung> bzw b -> editor?
            opt[UI_OPT_DESCRIPTION] = param;
            if (get_master()->set_x_frage(opt))
            {
                browse_write_line("Beschreibung gesetzt.");
                return B_REBUILT;
            }
            else
            {
                browse_write_line("Fehler beim Speichern.");
                return B_DONE;
            }
        case "ft":
            // TODO pruefen ob schon Auswertungen
            // TODO pruefen ob frei oder frei/erw. und Antworten vorhanden
            return menues + ({([
                B_TYPE : "x_fragen_typ_wahl",
                UI_OPT_XF_ID: menue[UI_OPT_XF_ID],
            ])});
        case "aa":
            ix = to_int(param);
            if (ix < -1)
            {
                browse_write_line("Ungültiger Wert.");
                return B_DONE;
            }
            opt[UI_OPT_ANZ_ANTWORTEN] = ix;
            if (get_master()->set_x_frage(opt))
            {
                browse_write_line("Anzahl Antworten gesetzt.");
                return B_REBUILT;
            }
            else
            {
                browse_write_line("Fehler beim Speichern.");
                return B_DONE;
            }
        case "a":
            return menues + ({([
                B_TYPE : "x_antworten_liste",
                UI_OPT_XF_ID: menue[UI_OPT_XF_ID],
            ])});
    }
    return B_NOTHING;    
}

//---------------------------------------------------------------------------
#define HELP_x_fragen_typ_wahl ({ \
"In dieser Ansicht wird der Fragentyp ausgewaehlt.",\
})

static mixed x_fragen_typ_wahl_init(mapping old)
{
    old[B_START_LINE] = 0;
    old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                     B_PROMPT : "Hilfe zur Auswahl des Fragentyps Zeile",
                     B_DATA : HELP_x_fragen_typ_wahl+HELP_standard ]);
    return old;
}

static int x_fragen_typ_wahl_total(mapping menue)
{
    return sizeof(UI_FRAGEN_TYP_LISTE);
}

static string * x_fragen_typ_wahl_display(mapping menue)
{
    string * liste = ({});
    int i;
    for (i=0;i<sizeof(UI_FRAGEN_TYP_LISTE);i++)
    {
        liste += ({sprintf("%02d %s",
            i+1,UI_FRAGEN_TYP_LISTE[i])});
    }
    menue[B_DATA] = liste;
    return staticmore_display(menue);
}

static string x_fragen_typ_wahl_prompt(mapping menue)
{
    return sprintf("Auswahl Fragentyp %d/%d [<nr>,z,q]",
        menue[B_CURRENT_LINE]+1,menue[B_END_LINE]);
}

static mixed x_fragen_typ_wahl_action(string str, mapping * menues)
{
    int ix = to_int(space(str));
    if (ix != 0)
    {
        if (ix <= 0 || ix >= sizeof(UI_FRAGEN_TYP_LISTE))
        {
            browse_write_line("Ungültiger Zahlenbereich");
            return B_DONE;
        }
        mapping opt = ([UI_OPT_XF_ID:menues[<2][UI_OPT_XF_ID] ]);
        opt[UI_OPT_FRAGEN_TYP] = ix - 1;
        if (get_master()->set_x_frage(opt))
        {
            browse_write_line("Fragentyp gesetzt.");
            menues[<2][B_FLAGS] |= BF_DIRTY;
            return menues[0..<2];
        }
        else
        {
            browse_write_line("Fehler beim Speichern.");
            return B_DONE;
        }
    }
    return B_NOTHING;
}

//---------------------------------------------------------------------------
#define HELP_x_antworten_liste ({ \
"In dieser Ansicht sind Fragen zur Wahl zu sehen.",\
})
static mixed x_antworten_liste_init(mapping old)
{
    old[B_START_LINE] = 0;
    old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                     B_PROMPT : "Hilfe zu Antworten Liste Zeile",
                     B_DATA : HELP_x_antworten_liste+HELP_standard ]);
    return old;
}

static int x_antworten_liste_total(mapping menue)
{
    return get_master()->get_xantworten(menue
        +([UI_OPT_COUNTALL:1]) );
}

static string * x_antworten_liste_display(mapping menue)
{
    mixed * xlines = get_master()->get_xantworten(menue
        +([UI_OPT_LIMIT:  menue[B_NUM_LINES],
           UI_OPT_OFFSET: menue[B_CURRENT_LINE] ]) );
    if (xlines == 0 || sizeof(xlines) <= 0) 
        return ({"Keine Antworten zur Auswahl!"});
    string * lines = ({});
    mapping cache = ([]);
    int i;
    for (i=0;i<sizeof(xlines);i++)
    {
        int ix = i+menue[B_CURRENT_LINE]+1;
        cache[ix] = xlines[i][0]; // id
        lines += ({ sprintf("%02d %s",
            ix,xlines[i][3]||"") }); // antwort
    }
    menue[UI_OPT_CACHE] = cache;
    return lines;
}

static string x_antworten_liste_prompt(mapping menue)
{
    return sprintf("Antworten %d,%d [<nr>,q,z,?]",
        menue[B_CURRENT_LINE]+1,menue[B_END_LINE]);
}

static mixed x_antworten_liste_action(string str, mapping * menues)
{
    string * split = explode(space(str)," ");
    mapping menue = menues[<1];
    mapping cache = menue[UI_OPT_CACHE]||([]);
    int ix = to_int(split[<1]);
    if (sizeof(split)==1 && ix > 0)
    {
        if (member(cache,ix))
        {
            return menues + ({([
                B_TYPE : "x_antwort_admin",
                UI_OPT_XA_ID : cache[ix],
            ])});
        }
        else
        {
            browse_write_line("Nummer passt nicht zur Anzeige.");
            return B_DONE;
        }
    }
    switch(split[0])
    {
        case "n": // neu
            if (!query_commander(TP))
            {
                browse_write_line("Keine Berechtigung zur Neuanlage.");
                return B_DONE;
            }
            ix = get_master()->create_x_antwort(menue[UI_OPT_XF_ID]);
            if (ix <= 0)
            {
                browse_write_line("Fehler beim Erstellen.");
                return B_DONE;
            }
            return menues + ({([
                B_TYPE : "x_antwort_admin",
                UI_OPT_XA_ID : ix,
            ])});   
        case "up":
            if (!query_commander(TP))
            {
                browse_write_line("Keine Berechtigung für die Sequenz.");
                return B_DONE;
            }
            if (!member(cache,ix))
            {
                browse_write_line("Ungültiges Element bei up <nr>");
                return B_DONE;
            }
            switch (get_master()->change_xantwort_seq(cache[ix],-1))
            {
                default:
                case 0:
                    browse_write_line("Interner Fehler Sequenzänderung.");
                    return B_DONE;
                case 1:
                    browse_write_line("Sequenz geändert.");
                    return B_REBUILT;
                case 2:
                    browse_write_line("Anfang erreicht.");
                    return B_DONE;
            }
        case "down":
            if (!query_commander(TP))
            {
                browse_write_line("Keine Berechtigung für die Sequenz.");
                return B_DONE;
            }
            if (!member(cache,ix))
            {
                browse_write_line("Ungültiges Element bei down <nr>");
                return B_DONE;
            }
            switch (get_master()->change_xantwort_seq(cache[ix],1))
            {
                default:
                case 0:
                    browse_write_line("Interner Fehler Sequenzänderung.");
                    return B_DONE;
                case 1:
                    browse_write_line("Sequenz geändert.");
                    return B_REBUILT;
                case 2:
                    browse_write_line("Ende erreicht.");
                    return B_DONE;
            }
    }
    return B_NOTHING;
}

