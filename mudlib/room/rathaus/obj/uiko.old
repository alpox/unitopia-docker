#define HELP_standard ({ \
"Im folgenden werden die Standardbefehle erlaeutert wobei die Angabe ohne ''",\
"anzugeben sind: 'd' blaettert eine Seite runter 'u' eine Seite nach oben.",\
"'<' blaettert an den Anfang zurueck, '>' blaettert ans Ende. ",\
"'q' Beendet das Menu, 'z' geht eine Menuebene hoeher, falls verfuegbar.",\
"'?' zeigt diese Hilfe.", \
})

#define HELP_idee_uebersicht_wahl ({ \
"In dieser Ansicht kann man die zur Wahl aktiven Ideen sehen. Diese sind ", \
"durchnummeriert und koennen ueber Angabe der Nummer angewaehlt werden. ",  \
"Mit f <begriff> kann in den Ideen nach einem Begriff gefiltert werden. ", \
"Mit N sind alle Ideen mit ungelesenen Diskussionen markiert. ", \
"mit gelesen/ungelesen kann man alle Ideen entsprechend markieren. ", \
})

#define HELP_idee_uebersicht_meine ({ \
"In dieser Ansicht kann man die eigenen Ideen sehen. Diese sind ", \
"durchnummeriert und koennen ueber Angabe der Nummer angewaehlt werden. ",\
"Mit f <begriff> kann in den Ideen nach einem Begriff gefiltert werden. ", \
"Mittels dem Befehl 'status' kann man nach Status filtern.",\
})


static mixed idee_uebersicht_init(mapping old)
{
    old[B_START_LINE] = 1;
    switch (old[UI_OPT_MENUTYPE])
    {
    case UI_MENUTYPE_WAHL:
        old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                         B_PROMPT : "Hilfe zu idee:wahl-Übersicht Zeile",
                         B_DATA : HELP_idee_uebersicht_wahl+HELP_standard ]);
        old[B_PROMPT] = "idee:wahl";
        break;
    case UI_MENUTYPE_OWN:
        old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                         B_PROMPT : "Hilfe zu idee:meine-Übersicht Zeile",
                         B_DATA : HELP_idee_uebersicht_meine+HELP_standard ]);
        old[B_PROMPT] = "idee:meine";
        break;
    case UI_MENUTYPE_BEREIT:
        old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                         B_PROMPT : "Hilfe zu idee:bereit-Übersicht Zeile",
                         B_DATA : HELP_idee_uebersicht_meine+HELP_standard ]);
        old[B_PROMPT] = "idee:bereit";
        break;
    case UI_MENUTYPE_ALLE:
        old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                         B_PROMPT : "Hilfe zu idee:alle-Übersicht Zeile",
                         B_DATA : HELP_idee_uebersicht_meine+HELP_standard ]);
        old[B_PROMPT] = "idee:alle";
        break;
    case UI_MENUTYPE_OFFEN:
        old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                         B_PROMPT : "Hilfe zu idee:offeneStimmen-Übersicht Zeile",
                         B_DATA : HELP_idee_uebersicht_wahl+HELP_standard ]);
        old[B_PROMPT] = "idee:offeneStimmen";
        break;
    case UI_MENUTYPE_DISKU:
        old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                         B_PROMPT : "Hilfe zu idee:diskussion-Übersicht Zeile",
                         B_DATA : HELP_idee_uebersicht_wahl+HELP_standard ]);
        old[B_PROMPT] = "idee:diskussion";
        old[UI_OPT_DISKUSSION] = 1;
        break;
    case UI_MENUTYPE_NDISKU:
        old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                         B_PROMPT : "Hilfe zu idee:keinediskussion-Übersicht Zeile",
                         B_DATA : HELP_idee_uebersicht_wahl+HELP_standard ]);
        old[UI_OPT_OHNE_DISKUSSION] = 1;
        old[B_PROMPT] = "idee:keinediskussion";
        break;
    case UI_MENUTYPE_IGNORIERT:
        old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                         B_PROMPT : "Hilfe zu idee:ignoriert-Übersicht Zeile",
                         B_DATA : HELP_idee_uebersicht_wahl+HELP_standard ]);
        old[B_PROMPT] = "idee:ignoriert";
        break;
    }
    return old;
}

private mapping idee_uebersicht_suchmuster(mapping menue)
{
    mapping opt = ([ UI_OPT_PANTHEON : wizp(TP) ]);
    mixed data;
    if (member(menue, UI_OPT_SUCHFILTER))
    {
        opt[UI_OPT_SUCHFILTER] = menue[UI_OPT_SUCHFILTER];
    }
    if (member(menue, UI_OPT_ERSTELLER))
    {
        opt[UI_OPT_ERSTELLER] = menue[UI_OPT_ERSTELLER];
    }
    if (member(menue, UI_OPT_UMFRAGE_OFFEN))
    {
        opt[UI_OPT_UMFRAGE_OFFEN] = menue[UI_OPT_UMFRAGE_OFFEN];
    }
    if (member(menue, UI_OPT_STATUS))
    {
        data = menue[UI_OPT_STATUS];
        if (intp(data))
        {
            selected_status = opt[UI_OPT_STATUS] = ({ menue[UI_OPT_STATUS] });
        }
        else if (pointerp(data))
        {
            selected_status = opt[UI_OPT_STATUS] = menue[UI_OPT_STATUS];
        }
        else if (sizeof(selected_status))
        {
            opt[UI_OPT_STATUS] = selected_status;
        }
    }
    if (member(menue, UI_OPT_DISKUSSION))
    {
        opt[UI_OPT_DISKUSSION] = menue[UI_OPT_DISKUSSION];
    }
    if (member(menue, UI_OPT_OHNE_DISKUSSION))
    {
        opt[UI_OPT_OHNE_DISKUSSION] = menue[UI_OPT_OHNE_DISKUSSION];
    }
    if (member(menue, UI_OPT_IGNORELIST))
    {
        opt[UI_OPT_IGNORELIST] = menue[UI_OPT_IGNORELIST];
    }
    return opt;
}

static mixed idee_uebersicht_reload(mixed menues)
{
    menues[<1] = idee_uebersicht_init(menues[<1]);
    menues[<1][B_FLAGS] &= ~BF_DIRTY;
    return menues;
}

static string * idee_uebersicht_display(mapping menue)
{
    int i;
    string c;
    mapping opt = idee_uebersicht_suchmuster(menue);
    mixed data;
    int total = get_master()->get_ideen_wahl_uebersicht(
                    opt+([UI_OPT_COUNTALL:1]) );
    int start = max(menue[B_START_LINE],
                min(menue[B_CURRENT_LINE]-1,total-menue[B_NUM_LINES]+1));
    opt[UI_OPT_OFFSET] = start-1;
    opt[UI_OPT_LIMIT] = menue[B_NUM_LINES]+1;
    data = get_master()->get_ideen_wahl_uebersicht(opt);
    string * content = ({});
    int end = min(total, start+menue[B_NUM_LINES]);
    //start = max(min(start, total - menue[B_NUM_LINES]),menue[B_START_LINE]);
    //PDBG(sprintf("idee_uebersicht_display %d/%d\n%Q\n%Q\n",
    //                                    start,end,opt,data));
    //if (start > sizeof(data))
    //    return 0;
    if (start < 1)
        start = 1;
    if (end < start) 
        return 0;
    for (i = start; i <= end; i++)
    {
        c = master->ist_idee_ungelesen(opt
                +([UI_OPT_I_ID : data[i-start][0]]), TP_RN) ? "N" : " ";
        content += ({ sprintf("%3d %s %s", i, c, data[i-start][1]) });
    }
    return content;
}

static int idee_uebersicht_total(mapping menue)
{
    mapping opt = idee_uebersicht_suchmuster(menue);
    opt[UI_OPT_COUNTALL] = 1;
    return get_master()->get_ideen_wahl_uebersicht(opt);
}

static string idee_uebersicht_prompt(mapping menue)
{
    string r = "Ideenuebersicht ";
    int total = idee_uebersicht_total(menue);
    int line = min(menue[B_CURRENT_LINE], total); // TODO workaround loesen
    if (member(menue, UI_OPT_SUCHFILTER))
    {
        r+= "<"+menue[UI_OPT_SUCHFILTER]+"> ";
    }
    if (member(menue, UI_OPT_ERSTELLER))
    {
        r+= "<"+menue[UI_OPT_ERSTELLER]+"> ";
    }
    r+= sprintf("%s Zeile %d/%d [q,z,?,<nr>]",menue[B_PROMPT], line, total);
    return r;
}

static mixed idee_uebersicht_action(string str, mapping * menues)
{
    mapping menue = menues[<1];
    int end = idee_uebersicht_total(menue);
    // int start = menue[B_CURRENT_LINE];
    int item;
    mapping opt = idee_uebersicht_suchmuster(menue);
    mixed r;
    string * parts = explode(space(str), " ");
    string param = implode(parts[1..]," ");
    switch (lower_case(parts[0]))
    {
    case "gelesen":
        get_master()->update_gelesen(opt, TP_RN);
        return B_REBUILT;
    case "ungelesen":
        get_master()->update_ungelesen(opt, TP_RN);
        return B_REBUILT;
    case "f":
    case "finde":
        if (stringp(param) && param != "")
        {
            menues[<1][UI_OPT_SUCHFILTER] = param;
        }
        else
        {
            m_delete(menues[<1],UI_OPT_SUCHFILTER);
        }
        menues[<1][B_FLAGS] |= ~BF_DIRTY;
        return menues;
    case "status":
        if (query_commander(TP) || menue[UI_OPT_MENUTYPE] == UI_MENUTYPE_OWN)
        {
            return menues+({ ([
                            B_TYPE : "status_wahl",
                            UI_OPT_MC : 1,
                          ]) });;
        }
        else
        {
            browse_write_line("Befehl Status nicht verfügbar.");
            return B_DONE;
        }
    case "bereit":
    case "aktiv":
    case "offen":
    case "beendet":
    case "abgelehnt":
        if (query_commander(TP) || menue[UI_OPT_MENUTYPE] == UI_MENUTYPE_OWN)
        {
            menues[<1][UI_OPT_STATUS] = selected_status = ({
                    get_status_id(capitalize(lower_case(parts[0]))) });
            return menues;
        }
        else
        {
            browse_write_line("Befehl "+parts[0]+" nicht verfügbar.");
            return B_DONE;
        }
    case "alle":
        if (query_commander(TP) || menue[UI_OPT_MENUTYPE] == UI_MENUTYPE_OWN)
        {
            m_delete(menues[<1],UI_OPT_STATUS);
            selected_status = ({ });
            return menues;
        }
        else
        {
            browse_write_line("Befehl "+parts[0]+" nicht verfügbar.");
            return B_DONE;
        }       
    default:
        if (!str2int(space(str),&item) && item >= 1 && item <= end)
        {
            opt[UI_OPT_OFFSET] = item-1;
            opt[UI_OPT_LIMIT] = 1;
            r = master->get_ideen_wahl_uebersicht(opt);
            //PDBG(sprintf("idee_uebersicht_action %Q %Q",opt,r));
            if (sizeof(r) == 1)
            {
                int i_id = r[0][0];
                menues[<1][B_CURRENT_LINE] = item;
                menues += ({ ([ B_TYPE : "idee_umfragen",
                                UI_OPT_I_ID : i_id,
                                UI_OPT_ITEM : item,
                                B_START_LINE : 0 ]) });
                return menues;
            }
        }
        break;
    }
    return B_NOTHING;
}

#define HELP_idee_umfragen ({ \
"In dieser Ansicht kann man eine Idee (i) mit all ihren Umfragen (U) sehen. ",\
"Diese sind durchnummeriert und koennen ueber Angabe der Nummer ",\
"angewaehlt werden. Mit '+' bzw. '-' kann die naechste bzw. vorherige Idee ",\
"angezeigt werden. Mit 'ignoriere' kann man das Ignorieren einzelner Ideen ", \
"an- und abschalten. Mit gelessen/ungelesen kann man die Diskussionen ", \
"entsprechend markieren.",  \
})
#define HELP_idee_umfragen_admin ({ \
"Mit Status kann der Status gesetzt werden, die Befehle bereit, aktiv, ",\
"offen, beendet, abgelehnt, archiviert machen das direkt.",  \
"Mittels uneu kann eine neue Umfrage hinzugefuegt werden.", \
"Mit aktuell kann man eine aktuelle Idee fuer alle setzen.", \
})
static mixed idee_umfragen_init(mapping old)
{
    int i;
    string * result = ({});
    mixed data = get_master()->get_ideen_wahl(([
            UI_OPT_I_ID : old[UI_OPT_I_ID],
            UI_OPT_PANTHEON : wizp(TP),
            ]));
    //PDBG(sprintf("idee_umfragen_init data %Q",data));
    if (!pointerp(data))
    {
        return B_QUIT;
    }
    for (i = 0; i< sizeof(data); i++)
    {
        result += ({ sprintf("%3d %s: %s",
                     i+1,
                     data[i][IDEEN_W_ZEICHEN],
                     data[i][IDEEN_W_TEXT] ) });
    }
    //PDBG(sprintf("idee_umfragen_init result %Q",result));
    old[UI_OPT_DATA] = data;
    old[B_DATA] = result;
    old[B_START_LINE] = 0;
    old[B_CURRENT_LINE] = 0;
    old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                     B_PROMPT : "Hilfe zu Idee x mit Umfragen Zeile",
                     B_DATA : HELP_idee_umfragen
                            +(query_commander(TP)?HELP_idee_umfragen_admin:({}))
                            +HELP_standard ]);
    return old;
}

static mixed idee_umfragen_reload(mixed menues)
{
    string str = menues[<1][UI_OPT_GOTO]||""; 
    int end, item, i_id;
    menues[<1][B_FLAGS] &= ~BF_DIRTY;
    switch (str)
    {
    case "+":
        item = 1;
        break;
    case "-":
        item = -1;
        break;
    default:
        return menues[..<2] + ({idee_umfragen_init(menues[<1])});
    }
    mapping menue = menues[<2];
    mapping opt = idee_uebersicht_suchmuster(menue);
    mixed r;
    end = idee_uebersicht_total(menue);
    item += menue[B_CURRENT_LINE];
    if (item < 1 || item > end)
    {
        browse_write_line("Anfang bzw. Ende der Daten erreicht.");
        return menues;
    }
    opt[UI_OPT_OFFSET] = item-1;
    opt[UI_OPT_LIMIT] = 1;
    r = master->get_ideen_wahl_uebersicht(opt);
    if (sizeof(r) == 1)
    {
        i_id = r[0][0];
        menue[B_CURRENT_LINE] = item;
        menues = menues[..<3] + ({menue}) +
                  ({ idee_umfragen_init( 
                     ([ B_TYPE : "idee_umfragen",
                        UI_OPT_I_ID : i_id,
                        UI_OPT_ITEM : item,
                        B_START_LINE : 0 ])) });
        return menues;
    }
    return menues;
}

static string * idee_umfragen_display(mapping menue)
{
    // string * result = ({});
    if (!mappingp(menue) )
        return 0;
    int start = menue[B_CURRENT_LINE];
    mixed * content = menue[B_DATA];
    int end = min(sizeof(content)-1, start+menue[B_NUM_LINES]);
    //start = min(start, end - menue[B_NUM_LINES]);
    if (start > sizeof(content))
        return 0;
    if (start < 0)
        start = 0;
    if (end < start) 
        return 0;
    return content[start..end];
}

static int idee_umfragen_total(mapping menue)
{
    return sizeof(menue[B_DATA]);
}

static string idee_umfragen_prompt(mapping menue)
{
    return sprintf("Idee Nr.%d mit Umfragen Zeile %d/%d [+,-,<nr>,z,q,?]",
        menue[UI_OPT_ITEM], 
        menue[B_CURRENT_LINE]+1,
        idee_umfragen_total(menue));
}

static mixed idee_umfragen_action(string str, mapping * menues)
{
    mapping menue = menues[<1];
    int i, item, end = sizeof(menue[B_DATA]);
    string * parts = explode(space(str), " ");
    // string param = implode(parts[1..]," ");
    get_master();
    
    switch(lower_case(parts[0]))
    {
    case "gelesen":
        master->update_gelesen(menue, TP_RN);
        return B_REBUILT;
    case "ungelesen":
        master->update_ungelesen(menue, TP_RN);
        return B_REBUILT;
    case "+":
    case "-":
        menues[<1][UI_OPT_GOTO] = space(str);
        menues[<1][B_FLAGS] |= BF_DIRTY;
        return menues;
    case "uneu":
        if (query_commander(TP))
        {
            umfrage_neu(menues, menues[<1][UI_OPT_I_ID]);
            return B_QUIT;
        }
        else
        {
            browse_write_line("Befehl uneu nicht verfügbar.");
            return B_DONE;
        }
    case "ignore":
    case "ignoriere":
        switch(get_master()->toggle_ignore_idee(menues[<1][UI_OPT_I_ID],TP_RN))
        {
        case 0:
            browse_write_line("Fehler beim Ignorieren.");
            break;
        case 1:
            browse_write_line("Idee wird nun ignoriert.");
            break;
        case -1:
            browse_write_line("Idee wird nicht mehr ignoriert.");
            break;
        }
        return B_DONE;
    case "aktuell":
        if (query_commander(TP))
        {
            get_master()->set_aktuelle_idee(menues[<1][UI_OPT_I_ID]);
            __FILE__->msg_to_clones("Uiko flüstert Dir zu:",
                "Es wurde eine neue, aktuelle Idee gesetzt. "
                "Aufruf mit idee:aktuell oder kurz i:a .");
            browse_write_line("Aktuelle Idee gesetzt.");
        }
        else
            browse_write_line("Befehl steht nicht zur Verfügung.");
        return B_DONE;
    case "bereit":
    case "aktiv":
    case "offen":
    case "beendet":
    case "abgelehnt":
    case "archiviert":
        if (query_commander(TP))
        {
            for (i=0;i<sizeof(menue[UI_OPT_DATA]);i++)
            {
                mixed * data = menue[UI_OPT_DATA][i];
                switch(data[IDEEN_W_ZEICHEN])
                {
                case "Idee":
                    master->aktualisiere_ideen_status(
                            data[IDEEN_W_I_ID],
                            get_status_id(capitalize(lower_case(parts[0]))));
                case "Umfrage":
                    master->aktualisiere_umfragen_status(
                            data[IDEEN_W_U_ID],
                            get_status_id(capitalize(lower_case(parts[0]))));
                case "Diskussion":
                    master->aktualisiere_diskussion_status(
                            data[IDEEN_W_U_ID], // ist das Feld fuer d_id hier.
                            get_status_id(capitalize(lower_case(parts[0]))));
                default:
                }
            }
            browse_write_line("Status aktualisiert");
            return B_DONE;
        }
        else
        {
            browse_write_line("Befehl "+parts[0]+" nicht verfügbar.");
            return B_DONE;
        }
   case "diskussion-s":
        if (query_commander(TP))
            return neue_diskussion("ideen", menues[<1][UI_OPT_I_ID], 1);
        else
            browse_write_line("Befehl steht nicht zur Verfügung.");
        return B_DONE;
   case "diskussion-p":
        if (query_commander(TP))
            return neue_diskussion("ideen", menues[<1][UI_OPT_I_ID], 2);
        else
            browse_write_line("Befehl steht nicht zur Verfügung.");
        return B_DONE;
   case "diskussion-sp":
        if (query_commander(TP))
            return neue_diskussion("ideen", menues[<1][UI_OPT_I_ID], 3);
        else
            browse_write_line("Befehl steht nicht zur Verfügung.");
        return B_DONE;
   default:
        if (!str2int(space(str),&item) && item >= 1 && item <= end)
        {
            mixed * data = menue[UI_OPT_DATA][item-1];
            switch (data[IDEEN_W_ZEICHEN])
            {
            case "Idee":
                menues += ({ ([ B_TYPE : "idee_details",
                        UI_OPT_I_ID : data[IDEEN_W_I_ID],
                        UI_OPT_ITEM : item,
                        B_START_LINE : 0 ]) });
                return menues;
            case "Umfrage":
                menues += ({ ([ B_TYPE : "umfrage_wahl",
                        UI_OPT_U_ID : data[IDEEN_W_U_ID],
                        UI_OPT_ITEM : item,
                        B_START_LINE : 0 ]) });
                return menues;
            case "Diskussion":
                menues += ({ ([ B_TYPE : "diskussion",
                        UI_OPT_D_ID : data[IDEEN_W_U_ID],
                        UI_OPT_ITEM : item,
                        B_PROMPT: data[IDEEN_W_TEXT],
                        B_START_LINE : 0 ]) });
                return menues;
            default:
                break;
            }
        }
        break;
    }
    return B_NOTHING;
}

#define HELP_idee_aktuell ({ \
"In dieser Ansicht kann man die aktuelle Idee (i) mit all ihren Umfragen (U)",\
"sehen. Diese sind durchnummeriert und koennen ueber Angabe der Nummer ",\
"angewaehlt werden. Mit 'ignoriere' kann man das Ignorieren der Idee an- ",\
"und abschalten.",  \
})
#define HELP_idee_aktuell_admin ({ \
"Mit Status kann der Status gesetzt werden, die Befehle bereit, aktiv, ",\
"offen, beendet, abgelehnt, archiviert machen das direkt.",  \
"Mittels uneu kann eine neue Umfrage hinzugefuegt werden.", \
})
static mixed idee_aktuell_init(mapping old)
{
    int i;
    string * result = ({});
    mixed data = get_master()->get_aktuelle_idee(([
            UI_OPT_PANTHEON : wizp(TP),
            ]));
    //PDBG(sprintf("idee_aktuell_init data %Q",data));
    if (!pointerp(data) || !sizeof(data))
    {
        browse_write_line("Zur Zeit ist keine aktuelle Idee gesetzt.");
        return B_QUIT;
    }
    for (i = 0; i< sizeof(data); i++)
    {
        result += ({ sprintf("%3d %s: %s",
                     i+1,
                     data[i][IDEEN_W_ZEICHEN],
                     data[i][IDEEN_W_TEXT] ) });
    }
    //PDBG(sprintf("idee_umfragen_init result %Q",result));
    old[UI_OPT_DATA] = data;
    old[B_DATA] = result;
    old[B_START_LINE] = 0;
    old[B_CURRENT_LINE] = 0;
    old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                     B_PROMPT : "Hilfe zur aktuellen Idee x Zeile",
                     B_DATA : HELP_idee_aktuell
                            +(query_commander(TP)?HELP_idee_aktuell_admin:({}))
                            +HELP_standard ]);
    return old;
}

static string * idee_aktuell_display(mapping menue)
{
    // string * result = ({});
    if (!mappingp(menue) )
        return 0;
    int start = menue[B_CURRENT_LINE];
    mixed * content = menue[B_DATA];
    int end = min(sizeof(content)-1, start+menue[B_NUM_LINES]);
    //start = min(start, end - menue[B_NUM_LINES]);
    if (start > sizeof(content))
        return 0;
    if (start < 0)
        start = 0;
    if (end < start) 
        return 0;
    return content[start..end];
}

static int idee_aktuell_total(mapping menue)
{
    return sizeof(menue[B_DATA]);
}

static string idee_aktuell_prompt(mapping menue)
{
    return sprintf("Aktuelle Idee mit Umfragen Zeile %d/%d [<nr>,z,q,?]",
        menue[B_CURRENT_LINE]+1,
        idee_umfragen_total(menue));
}

static mixed idee_aktuell_action(string str, mapping * menues)
{
    mapping menue = menues[<1];
    int i, item, end = sizeof(menue[B_DATA]);
    string * parts = explode(space(str), " ");
    // string param = implode(parts[1..]," ");
    get_master();
    
    switch(lower_case(parts[0]))
    {
    case "uneu":
        if (query_commander(TP))
        {
            umfrage_neu(menues, menues[<1][UI_OPT_I_ID]);
            return B_QUIT;
        }
        else
        {
            browse_write_line("Befehl uneu nicht verfügbar.");
            return B_DONE;
        }
    case "ignore":
    case "ignoriere":
        switch(get_master()->toggle_ignore_idee(menues[<1][UI_OPT_I_ID],TP_RN))
        {
        case 0:
            browse_write_line("Fehler beim Ignorieren.");
            break;
        case 1:
            browse_write_line("Idee wird nun ignoriert.");
            break;
        case -1:
            browse_write_line("Idee wird nicht mehr ignoriert.");
            break;
        }
        return B_DONE;
    case "bereit":
    case "aktiv":
    case "offen":
    case "beendet":
    case "abgelehnt":
    case "archiviert":
        if (query_commander(TP))
        {
            for (i=0;i<sizeof(menue[UI_OPT_DATA]);i++)
            {
                mixed * data = menue[UI_OPT_DATA][i];
                switch(data[IDEEN_W_ZEICHEN])
                {
                case "Idee":
                    master->aktualisiere_ideen_status(
                            data[IDEEN_W_I_ID],
                            get_status_id(capitalize(lower_case(parts[0]))));
                case "Umfrage":
                    master->aktualisiere_umfragen_status(
                            data[IDEEN_W_U_ID],
                            get_status_id(capitalize(lower_case(parts[0]))));
                default:
                }
            }
            browse_write_line("Status aktualisiert");
            return B_DONE;
        }
        else
        {
            browse_write_line("Befehl "+parts[0]+" nicht verfügbar.");
            return B_DONE;
        }
   default:
        if (!str2int(space(str),&item) && item >= 1 && item <= end)
        {
            mixed * data = menue[UI_OPT_DATA][item-1];
            switch (data[IDEEN_W_ZEICHEN])
            {
            case "Idee":
                menues += ({ ([ B_TYPE : "idee_details",
                        UI_OPT_I_ID : data[IDEEN_W_I_ID],
                        UI_OPT_ITEM : item,
                        B_START_LINE : 0 ]) });
                return menues;
            case "Umfrage":
                menues += ({ ([ B_TYPE : "umfrage_wahl",
                        UI_OPT_U_ID : data[IDEEN_W_U_ID],
                        UI_OPT_ITEM : item,
                        B_START_LINE : 0 ]) });
                return menues;
            default:
                break;
            }
        }
        break;
    }
    return B_NOTHING;
}



#define HELP_idee_details ({ \
"In dieser Ansicht kann man eine Idee mit Titel umd Zusammenfassung sehen.",  \
"Mit 'ignoriere' kann man das Ignorieren der Idee an- und abschalten.", \
})
#define HELP_idee_details_admin ({ \
"Mit Status kann der Status gesetzt werden, die Befehle bereit, aktiv, ",\
"offen, beendet, abgelehnt, archiviert machen das direkt.",  \
})
static mixed idee_details_init(mapping old)
{
    int i_id = old[UI_OPT_I_ID], i_st, i_pa;
    string * r2,*r1 = get_master()->get_idee(i_id);
    if (sizeof(r1) != 2)
    {
        browse_write_line("Idee nicht vorhanden.");
        return B_QUIT;
    }
    r2 = ({ "Titel: "+r1[0] });
    i_st = master->get_ideen_status(i_id);
    i_pa = master->get_ideen_pantheon(i_id);
    r2 += ({ "Status: "+get_status(i_st)+" "+PANTHEON2TEXT(i_pa) });
    if (query_commander(TP))
    {
        r2+= ({ "I_ID:"+i_id+" Ersteller: "+master->get_ideen_ersteller(i_id)});
    }
    r2 += explode(r1[1], "\n");
    old[B_DATA] = r2;
    old[B_START_LINE] = 0;
    old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                     B_PROMPT : "Hilfe zu Ideendetailansicht Zeile",
                     B_DATA : HELP_idee_details
                            +(query_commander(TP)?HELP_idee_details_admin:({}))
                            +HELP_standard ]);
    return old;
}

static mixed idee_details_reload(mixed menues)
{
    menues[<1] = idee_details_init(menues[<1]);
    menues[<1][B_FLAGS] &= ~BF_DIRTY;
    return menues;
}

static string * idee_details_display(mapping menue)
{
    return staticmore_display(menue);
}

static int idee_details_total(mapping menue)
{
    return sizeof(menue[B_DATA]);
}

static string idee_details_prompt(mapping menue)
{
    return sprintf("Ideendetailansicht Zeile %d/%d) [q,z,?]",
        menue[B_CURRENT_LINE]+1, sizeof(menue[B_DATA]) );
}

static mixed idee_details_action(string str, mapping * menues)
{
    string * parts = explode(space(str), " ");
    // string param = implode(parts[1..]," ");
    get_master();
    
    switch(lower_case(parts[0]))
    {
    case "ignore":
    case "ignoriere":
        switch(get_master()->toggle_ignore_idee(menues[<1][UI_OPT_I_ID],TP_RN))
        {
        case 0:
            browse_write_line("Fehler beim Ignorieren.");
            break;
        case 1:
            browse_write_line("Idee wird nun ignoriert.");
            break;
        case -1:
            browse_write_line("Idee wird nicht mehr ignoriert.");
            break;
        }
        return B_DONE;
    case "status":
        if (query_commander(TP))
        {
            return menues+({ ([
                            B_TYPE : "status_wahl",
                            UI_OPT_STATUS : 
                get_master()->get_ideen_status(menues[<1][UI_OPT_I_ID])
                          ]) });;
        }
        else
        {
            browse_write_line("Befehl Status nicht verfügbar.");
            return B_DONE;
        }
    case "bereit":
    case "aktiv":
    case "offen":
    case "beendet":
    case "abgelehnt":
    case "archiviert":
        if (query_commander(TP))
        {
            master->aktualisiere_ideen_status(
                    menues[<1][UI_OPT_I_ID],
                    get_status_id(capitalize(lower_case(parts[0]))));
            browse_write_line("Status aktualisiert");
        }
        else
        {
            browse_write_line("Befehl "+parts[0]+" nicht verfügbar.");
        }
        return B_DONE;
    }
    return B_NOTHING;
}

#define HELP_umfrage_wahl ({ \
"In dieser Ansicht kann man eine Umfrage optional mit der zugehoerigen Idee ",\
"zu sehen. Alle moeglichen Antworten sind dargestellt, die mit der Nummer ", \
"auszuwaehlen sind. Ein * kennzeichnet die Wahl, die man getaetigt hat.",  \
})
#define HELP_umfrage_wahl_admin ({ \
"Mit Status kann der Status gesetzt werden, die Befehle bereit, aktiv, ",\
"offen, beendet, abgelehnt, archiviert machen das direkt.",  \
"Mittels aneu kann im Status neu und bereit eine neue Antwort ",\
"hinzugefuegt werden",\
})
static mixed umfrage_wahl_init(mapping old)
{
    int u_id = old[UI_OPT_U_ID],u_st,u_pa;
    mixed r1 = get_master()->get_ideen_wahl(([
            UI_OPT_U_ID:u_id,
            UI_OPT_PANTHEON : wizp(TP)?1:0,
            ]));
    string sel,*lines = ({});
    int i,a_id;
    if (sizeof(r1)==2)
    {
        for (i = 0; i< 2; i++)
        {
            lines  += ({ sprintf("%s: %s",
                         r1[i][IDEEN_W_ZEICHEN],
                         r1[i][IDEEN_W_TEXT] ) });
        }
        u_st = master->get_umfragen_status(u_id);
        u_pa = master->get_umfragen_pantheon(u_id);
        lines += ({ "Status: "+get_status(u_st)+" "+PANTHEON2TEXT(u_pa) });
        if (query_commander(TP))
        {
            lines+= ({ "U_ID:"+u_id+" Ersteller: "
                    +master->get_umfragen_ersteller(u_id) });
        }
    }
    else
    {
        r1 = master->get_umfrage(old[UI_OPT_U_ID]);
        if (stringp(r1))
        {
            lines  += ({ sprintf("0 Umfrage: %s",r1) }) ;
        }
        else
        {
            browse_write_line("Keine Umfrage gefunden.");
            return B_QUIT;
        }
        u_st = master->get_umfragen_status(u_id);
        u_pa = master->get_umfragen_pantheon(u_id);
        lines += ({ "Status: "+get_status(u_st)+" "+PANTHEON2TEXT(u_pa) });
        if (query_commander(TP))
        {
            lines+= ({ "U_ID:"+u_id+" Ersteller: "
                    +master->get_umfragen_ersteller(u_id) });
        }
    }
    lines += ({ "Antworten auf die aktuelle Umfrage:" });
    r1 = master->get_antworten(old[UI_OPT_U_ID]);
    a_id = master->hat_gewaehlt(old[UI_OPT_U_ID],TP_RN);
    for (i = 0; i<sizeof(r1); i++)
    {
        sel = (a_id == r1[i][0])? "*" :" ";
        lines += ({ sprintf("%s%2d %s",sel,i+1,r1[i][1]) });
    }
    old[B_DATA] = lines;
    old[UI_OPT_DATA] = r1;
    old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                     B_PROMPT : "Hilfe zu Umfragenabstimmung Zeile",
                     B_DATA : HELP_umfrage_wahl
                            +(query_commander(TP)?HELP_umfrage_wahl_admin:({}))
                            +HELP_standard ]);
    return old;
}

static mixed umfrage_wahl_reload(mixed menues)
{
    if (strstr(get_menue_path(menues),
            "umfrage_wahl/idee_umfragen/idee_uebersicht")==0)
    {
        ;
    }
    mixed m = umfrage_wahl_init(menues[<1]);
    if (mappingp(m))
    {
        m[B_FLAGS] &= ~BF_DIRTY;
        return menues[..<2] + ({ m });
    }
    return m;
}

static string * umfrage_wahl_display(mapping menue)
{
    return staticmore_display(menue);
}

static int umfrage_wahl_total(mapping menue)
{
    return sizeof(menue[B_DATA]);
}

static string umfrage_wahl_prompt(mapping menue)
{
    return sprintf("Umfragenabstimmung Zeile:%d/%d [q,z,?,<nr>]",
        menue[B_CURRENT_LINE],sizeof(menue[B_DATA]));
}

static mixed umfrage_wahl_action(string str, mapping * menues)
{
    int item,end,a_id, u_id = menues[<1][UI_OPT_U_ID];
    mapping menue = menues[<1];
    mixed data = menue[UI_OPT_DATA];
    end = sizeof(data);
    string * parts = explode(space(str), " ");
    string param = implode(parts[1..]," ");
    get_master();
    
    switch(lower_case(parts[0]))
    {
    case "aneu":
        if (query_commander(TP))
        {
            if (!param || param == "")
            {
                input_to(#'umfrage_neue_antwort, INPUT_PROMPT, 
                         "Neue Antwort:",menues,u_id);
            }
            else
            {
                umfrage_neue_antwort(param, menues, u_id);
            }
            return B_QUIT;
        }
        else
        {
            browse_write_line("Befehl aneu nicht verfügbar.");
            return B_DONE;
        }
    case "status":
        if (query_commander(TP))
        {
            return menues+({ ([
                            B_TYPE : "status_wahl",
                            UI_OPT_STATUS : 
                master->get_umfragen_status(u_id)
                          ]) });;
        }
        else
        {
            browse_write_line("Befehl Status nicht verfügbar.");
            return B_DONE;
        }
    case "bereit":
    case "aktiv":
    case "offen":
    case "beendet":
    case "abgelehnt":
    case "archiviert":
        if (query_commander(TP))
        {
            master->aktualisiere_umfragen_status(
                    menues[<1][UI_OPT_U_ID],
                    get_status_id(capitalize(lower_case(parts[0]))));
            browse_write_line("Status aktualisiert");
        }
        else
        {
            browse_write_line("Befehl "+parts[0]+" nicht verfügbar.");
        }
        return B_DONE;
    default:
        if (!str2int(space(str),&item) && item >= 1 && item <= end)
        {
            a_id = data[item-1][0];
            if (master->add_erhebung(a_id, TP_RN,wizp(TP)!=0))
            {
                browse_write_line("Wahl erfolgt.");
                menue[B_FLAGS] |= BF_DIRTY;
                menues[<1] = menue;
                return menues;
            }
            else
            {
                browse_write_line("Wahl nicht erfolgt.");
                return B_DONE;
            }
        }
        break;
    }
    return B_NOTHING;
}

#define HELP_status_wahl_mc ({ \
"In dieser Ansicht kann man einen oder mehrere Status ueber <nr> auswaehlen.",\
})
#define HELP_status_wahl ({ \
"In dieser Ansicht kann man genau einen Status ueber <nr> auswaehlen.",\
})
#define HELP_status_wahl_liste ({ \
"Die Bedeutung der einzelnen Status ist wie folgt:",\
"Geloescht: ist ein interner Status, der nicht angewaehlt werden kann.",\
"Neu: ist ein Zustand beim Anlegen der Idee oder Umfrage.",\
"Standard: sind Ideen und Umfragen, die als Vorlage dienen sollen.",\
"Bereit: sind alle Ideen und Umfragen, die auf Freigabe warten.",\
"Aktiv: sind alle Ideen und Umfragen, die zur Wahl stehen.",\
"Offen: sind die Umfragen, wo man Antworten frei ergaenzen kann.",\
"Beendet: sind Ideen und Umfragen, welche so oder so aehnlich umgesetzt wurden.",\
"Abgelehnt: sind die abgelehnten Ideen.",\
"Archiviert: sind veraltete Ideen und Umfragen",\
})

static mixed status_wahl_init(mapping old)
{
    selected = selected_status;
    if (member(old,UI_OPT_STATUS))
    {
        if (intp(old[UI_OPT_STATUS]))
        {
            selected = ({ old[UI_OPT_STATUS] });
        }
        else if (pointerp(old[UI_OPT_STATUS]))
        {
            selected = old[UI_OPT_STATUS];
        }
    }
   if (member(old, UI_OPT_MC))
   {
        old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                         B_PROMPT : "Hilfe zu Mehrfach-Statusauswahl Zeile", 
                         B_DATA : HELP_status_wahl_mc+HELP_standard
                                 +HELP_status_wahl_liste]);
   }
   else
   {
        old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                         B_PROMPT : "Hilfe zu Statusauswahl Zeile", 
                         B_DATA : HELP_status_wahl+HELP_standard
                                 +HELP_status_wahl_liste ]);
   }
   old[B_START_LINE] = 1;
   return old;
}

static string * status_wahl_display(mapping menue)
{
    int i;
    string sel,* result = ({});
    for (i=UMFRAGE_S_GELOESCHT; i <= UMFRAGE_S_ARCHIVIERT; i++)
    {
        sel = (member(selected,i)!=-1) ? "*" : " ";
        result += ({ sprintf("%s %d %s", sel, i+1, get_status(i)) });
    }
    return result;
}

static int status_wahl_total(mapping menue)
{
    return UMFRAGE_S_ARCHIVIERT+1;
}

static string status_wahl_prompt(mapping menue)
{
    return member(menue,UI_OPT_MC) ? 
            "Mehrfach-Statusauswahl [<nr>,z,q,?]" :
            "Statusauswahl [<nr>,z,q,?]";
}

static mixed status_wahl_action(string str, mapping * menues)
{
    int item, i;
    string path = get_menue_path(menues);
    get_master();
    // PDBG("status_wahl_action: "+path);
    if (space(str)=="z")
    {
        if (strstr(path,
            "status_wahl/idee_uebersicht")==0)
        {
            selected_status = selected;
            if (sizeof(selected_status))
            {
                menues[<2][UI_OPT_STATUS] = selected_status;
            }
            else
            {
                menues[<2][UI_OPT_STATUS] = UMFRAGE_S_AKTIV;
            }
        }
        else if (strstr(get_menue_path(menues),
            "status_wahl/umfrage_wahl")==0)
        {
            item = menues[<2][UI_OPT_U_ID];
            if (sizeof(selected))
            {
                master->aktualisiere_umfragen_status(item,selected[0]);
            }
        }
        else if (strstr(get_menue_path(menues),
            "status_wahl/idee_details")==0)
        {
            item = menues[<2][UI_OPT_I_ID];
            if (sizeof(selected))
            {
                master->aktualisiere_ideen_status(item,selected[0]);
            }
        }
        else if (strstr(get_menue_path(menues),
            "status_wahl/x_umfrage_admin")==0)
        {
            if (sizeof(selected))
            {
                mapping opt = master->get_x_umfrage(TP,
                    menues[<2][UI_OPT_XU_ID]);
                opt[UI_OPT_STATUS] = selected[0];
                master->set_x_umfrage(TP,opt);
            }
        }
        else
        {
            browse_write_line("Unbekannter Pfad");
            return B_DONE;
        }
        menues[<2][B_FLAGS] |= BF_DIRTY;
        return B_NOTHING;
    }
    if (!str2int(space(str),&item) 
            && item > UMFRAGE_S_NEU && item <= UMFRAGE_S_ARCHIVIERT+1)
    {
        item--;
        if (member(menues[<1], UI_OPT_MC))
        {
            if ((i=member(selected,item)) != -1)
            {
                selected = arr_delete(selected,i);
            }
            else
            {
                selected += ({ item });
            }
        }
        else 
        {
            if ((i=member(selected,item)) != -1)
            {
                selected = arr_delete(selected,i);
            }
            else
            {
                selected = ({ item });
            }
        }
        return B_REBUILT;
    }
    return B_NOTHING;
}

#define HELP_ideen_auswertung ({ \
"In dieser Ansicht sind die Ideen inkl. Auswertung angezeigt und",\
"absteigend sortiert. Per <nr> kann man eine Idee auswaehlen.",\
})
static mixed ideen_auswertung_init(mapping old)
{
    mixed * data = get_master()->get_erhebung_alle_ideen(old);
    string * list = ({ });
    int i;
    if (!query_commander(TP) || TI!=TP) return B_QUIT;
    for (i=0; i < sizeof(data);i ++)
    {
        list += ({  sprintf("%3d %11s %60s",i+1,
            data[i][UI_ERHEBUNG1I_SCHLUESSEL],
            data[i][UI_ERHEBUNG1I_TEXT] )
            });
    }
   old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                    B_PROMPT : "Hilfe zur Auswertung Zeile", 
                    B_DATA : HELP_ideen_auswertung+HELP_standard ]);
    old[B_DATA] = list;
    old[B_START_LINE] = 0;
    old[UI_OPT_DATA] = data;
    return old;
}

static string * ideen_auswertung_display(mapping menue)
{
    return staticmore_display(menue);
}

static int ideen_auswertung_total(mapping menue)
{
    return sizeof(menue[UI_OPT_DATA]);
}

static string ideen_auswertung_prompt(mapping menue)
{
    int ix = menue[B_CURRENT_LINE];
    int ex = ideen_auswertung_total(menue);
    return sprintf("Ideen Auswertung $d/%d [u,d,<nr>,?,q]",ix,ex);
}

static mixed ideen_auswertung_action(string str, mapping * menues)
{
    int item, i_id;
    mapping menue = menues[<1];
    if (!str2int(space(str),&item) 
            && item > 0 && item <= sizeof(menue[UI_OPT_DATA]))
    {
        item--;
        i_id = menue[UI_OPT_DATA][item][UI_ERHEBUNG1I_I_ID];
        
        menues[<1][B_CURRENT_LINE] = item;
        menues += ({ ([ B_TYPE : "idee_umfragen",
                        UI_OPT_I_ID : i_id,
                        UI_OPT_ITEM : item,
                        B_START_LINE : 0 ]) });
        return menues;
    }
    return B_NOTHING;
}

#define HELP_diskussion ({ \
"In dieser Ansicht ist die Uebersicht ueber die Beitraege.",\
"Mit gelesen/ungelesen kann man alle Beitraege entsprechend markieren.",\
})
static mixed diskussion_init(mapping old)
{
   old[B_HELP] = ([ B_TYPE : B_STATICMORE,
                    B_PROMPT : "Hilfe zur Auswertung Zeile", 
                    B_DATA : HELP_diskussion+HELP_standard ]);
   return old;
}

static int diskussion_total(mapping menue)
{
    return get_master()->get_diskussionsbeitraege(
                     menue+([UI_OPT_COUNTALL:1,
                     UI_OPT_PANTHEON:wizp(TP)]) );
}

static string * diskussion_display(mapping menue)
{
    string * result = ({}), c;
    if (!mappingp(menue) )
        return 0;
    mixed data = get_master()->get_diskussionsbeitraege(menue
            +([UI_OPT_PANTHEON:wizp(TP)]) );
    int start = menue[B_CURRENT_LINE];
    int end = min(diskussion_total(menue), start+menue[B_NUM_LINES]);
    start = min(start, end - menue[B_NUM_LINES]);
    int i;
    if (start < 0)
        start = 0;
    if (end < start) 
        return 0;
    for(i=start;i<end;i++)
    {
        c = master->ist_beitrag_ungelesen(
                data[i-start][UI_BEITRAG_B_ID], TP_RN) ? "N" : " ";
        result += ({ sprintf("%3d %s %s %10s %s",i,c, 
                shorttimestr(data[i-start][UI_BEITRAG_WANN]),
                data[i-start][UI_BEITRAG_WER],
                data[i-start][UI_BEITRAG_TITEL] ) });
    }
    return result;

}

static string diskussion_prompt(mapping menue)
{
    int ix = menue[B_CURRENT_LINE];
    int ex = diskussion_total(menue);
    return sprintf("Diskussionsbeiträge %s %d/%d [u,d,neu,<nr>,?,q]",
            menue[B_PROMPT]||"",ix,ex);
}

static mixed diskussion_action(string str, mapping * menues)
{
    int item, b_id;
    mapping menue = menues[<1];
    switch (lower_case(space(str)))
    {
    case "gelesen":
        get_master()->update_gelesen(menue, TP_RN);
        return B_REBUILT;
    case "ungelesen":
        get_master()->update_ungelesen(menue, TP_RN);
        return B_REBUILT;
    case "neu":
        diskussionsbeitrag_neu(menues, menues[<1][UI_OPT_D_ID]);
        return B_QUIT;
    case "z":
        menues[<2][B_FLAGS] |= BF_DIRTY;
        return B_NOTHING;
    default:
        if (!str2int(space(str),&item) && item >= 0)
        {
            mixed data = get_master()->get_diskussionsbeitraege(menue
                +([UI_OPT_PANTHEON:wizp(TP), 
                    UI_OPT_OFFSET : item, UI_OPT_LIMIT : 1 ]) );
            if (data == 0 || sizeof(data)!=1)
            {
                break;
            }
            b_id = data[0][UI_BEITRAG_B_ID];
            
            menues[<1][B_CURRENT_LINE] = item;
            menues += ({ ([ B_TYPE : "beitrag",
                            UI_OPT_B_ID : b_id,
                            UI_OPT_ITEM : item,
                            B_START_LINE : 0 ]) });
            return menues;
        }
    }
    return B_NOTHING;
}

