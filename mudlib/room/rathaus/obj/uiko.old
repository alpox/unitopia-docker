private int inp2_frage(string uidp,string val,
    mapping l_options,mapping *l_data)
{
    mapping l_frage = l_data[L_DATA_FRAGE];
    switch (l_frage[UI_OPT_FRAGEN_TYP])
    {
        case UI_FRAGEN_TYP_FREI:
            list_antworten(uidp,val,l_options,l_data);
            switch (l_frage[UI_OPT_ANZ_ANTWORTEN])
            {
                case 1:
                    input_to(#'inp_frage_frei_einzel,INPUT_PROMPT,
        "Eine Antwort über Nummer auswählen: ",
                        uidp,val,l_options,l_data);
                    return -1;
                case 0:
                    input_to(#'inp_frage_frei_multi,INPUT_PROMPT,
        "Beliebige Antworten über Nummer auswählen, f wenn fertig: ",
                        uidp,val,l_options,l_data);
                    return -1;
                default:
                    input_to(#'inp_frage_frei_multi,INPUT_PROMPT,
        sprintf("%d Antworten über Nummer auswählen, f wenn fertig: ",
                        l_frage[UI_OPT_ANZ_ANTWORTEN]),
                        uidp,val,l_options,l_data);
                    return -1;
            }
        case UI_FRAGEN_TYP_FREI_ERWEIT:
            list_antworten(uidp,val,l_options,l_data);
            switch (l_frage[UI_OPT_ANZ_ANTWORTEN])
            {
                case 1:
                    input_to(#'inp_frage_frei_einzel,INPUT_PROMPT,
  "Eine Antwort über Nummer auswählen, s für sonstige Antwort ergänzen: ",
                        uidp,val,l_options,l_data);
                    return -1;
                case 0:
                    input_to(#'inp_frage_frei_multi,INPUT_PROMPT,
  "Beliebige Antworten über Nummer auswählen, s für sonstige Antworten\n"
  "f für fertig: ",
                        uidp,val,l_options,l_data);
                    return -1;
                default:
                    input_to(#'inp_frage_frei_multi,INPUT_PROMPT,
  sprintf("%d Antworten über Nummer auswählen, s für sonstige Antworten\n"
  "f für fertig: ", l_frage[UI_OPT_ANZ_ANTWORTEN]),
                        uidp,val,l_options,l_data);
                    return -1;
            }
        case UI_FRAGEN_TYP_ZEIT3_3_10:
            list_zeit3_3_10(val);
            input_to(#'inp_frage_zeit3_3_10,INPUT_PROMPT,
                "Eine Antwort 1 bis 4 wählen: ",uidp,val,l_options,l_data);
            return -1;
        case UI_FRAGEN_TYP_SCHLECHT5GUT:
            list_schlecht5gut(val);
            input_to(#'inp_frage_schlecht5gut,INPUT_PROMPT,
                "Eine Antwort 1 bis 5 wählen: ",uidp,val,l_options,l_data);
            return -1;
        case UI_FRAGEN_TYP_KOMMENTAR:
            // TODO editor!
        default:
        case UI_FRAGEN_TYP_GILDE:
            browse_write_line("Unbekannter Fragentyp");
            return 0;
    }
    return 0;
}

private void loop_x_umfrage(mapping l_options,mapping *l_data)
{
    mapping m_data;
    if (!mappingp(l_options))
    {
        debuglog("Parameterfehler l_options",DB_DBGLVL_ERROR,TP_RN,
            "uiko:loop_x_umfrage");
        return;
    }
    string usr = l_options[UI_OPT_USER_NAME];
    if (!stringp(usr)||!player_exists(usr))
    {
        debuglog("Parameterfehler usr",DB_DBGLVL_ERROR,TP_RN,
            "uiko:loop_x_umfrage");
        return;
    }
    if (!sizeof(l_data))
    {
        m_data = get_master()->get_x_umfrage(l_options[UI_OPT_XU_ID]);
        if (!mappingp(m_data))
        {
            debuglog("Parameterfehler xu_id",DB_DBGLVL_ERROR,usr,
                "uiko:loop_x_umfrage");
            return;
        }
        l_data = ({m_data});
    }
    while (42)
    {
        string uidp = update_unified_path(l_options,l_data);
        string val = master->get_x_auswertung(uidp,usr);
        int update_level = -1;
        switch (sizeof(l_data))
        {
            case 1: // umfrage
                if (!val || 
                    ((l_options[UI_OPT_LOOP_MODE] & UI_LOOP_RESTART)>0) )
                {
                    browse_write_line("Start Umfrage: "+
                        l_data[L_DATA_UMFRAGE][UI_OPT_TITLE]);
                }
                update_level = L_DATA_THEMA;
                break;
            case 2: // umfrage|thema
                debuglog("Level 2 thema ohne variant?",DB_DBGLVL_ERROR,usr,
                    "uiko:loop_x_umfrage");
                return;
            case 3: // umfrage|thema|variant/gilde
                update_level = L_DATA_FRAGE;
                break;
            case 4: // umfrage|thema|variant/gilde|frage
                switch (inp2_frage(uidp,val,l_options,l_data))
                {
                    case 0: // Fehler
                        return; 
                    case -1:
                        return; // input to aktiv...
                }
        }
        if (update_level == L_DATA_FRAGE)
        {
            switch(get_next_x_frage(l_options,l_data))
            {
                case -3:
                    update_level = L_DATA_THEMA;
                    break;
                case 0:
                    return;
                case 1:
                    continue;
            }
        }
        if (update_level == L_DATA_THEMA)
        {
            uidp = implode(l_options[UI_OPT_UNIFIED_PATH][0..2],"|");
            get_master()->set_x_auswertung(
                uidp,
                l_options[UI_OPT_USER_NAME],
                "START",
                l_options[UI_OPT_USER_TYPE],
                l_options[UI_OPT_GILDE]
            );
            switch(get_next_x_thema(l_options,l_data))
            {
                case -3:
                    browse_write_line("Ende der Umfrage erreicht.");
                    // TODO Endemarkierung?
                    return;
                case -2: // keine weiteren gilden, wurde abgefangen
                    continue;
                case -1: // input_to ist aktiv
                    return;
                case 0: // fehler
                    return;
                case 1: // no variant
                    continue;
            }
        }
    }
}

//---------------------------------------------------------------------------

private void idee_neu_pantheon(string str)
{
    int flag;
    switch (lower_case(space(str)))
    {
    case "~q":
    case ".":
        send_message_to(TP, MT_LOOK, MA_READ, wrap("Idee abgebrochen."));
        set_pl_tmp(TP, 0, 0);
        return;
    case "s":
        flag = 0;
        break;
    case "p":
        flag = 1;
        break;
    default:
        input_to(#'idee_neu_pantheon, INPUT_PROMPT, 
            "Sollen die Idee (S)pieler und Pantheon \n"
            "oder nur das (P)antheon sehen? (S/P/~q):");
        return;
    }
    int i_id = get_master()->add_idee(
                    query_pl_tmp(TP,"Titel"),
                    query_pl_tmp(TP,"Inhalt"),
                    TP_RN, UMFRAGE_S_NEU, flag);
    set_pl_tmp(TP, 0, 0);
    if (i_id <= 0)
    {
        send_message_to(TP, MT_LOOK, MA_READ, 
            wrap("Fehler beim Anlegen der Idee."));
        return;
    }
    int u_id = master->add_umfrage(
                    "Wie gefällt Dir die Idee?",
                    TP_RN, UMFRAGE_S_NEU, i_id, flag);
    if (u_id <= 0)
    {
        send_message_to(TP, MT_LOOK, MA_READ, 
            wrap("Fehler beim Anlegen der Umfrage zur Idee."));
        return;
    }
    if (  master->add_antwort(u_id, "Mag ich") <= 0
        || master->add_antwort(u_id, "Neutral") <= 0
        || master->add_antwort(u_id, "Mag ich nicht") <= 0)
    {
        send_message_to(TP, MT_LOOK, MA_READ, 
            wrap("Fehler beim Anlegen der Antworten zur Idee."));
        return;
    }
    if ( master->aktiviere_idee_und_umfrage(i_id, u_id) <= 0)
    {
        send_message_to(TP, MT_LOOK, MA_READ, 
            wrap("Fehler beim Aktivieren der Idee."));
        return;
    }
    send_message_to(TP, MT_LOOK, MA_READ, 
        wrap("Idee erfolgreich bereitgestellt, warten auf Adminfreigabe."));
    PDBG("Neue Idee von "+TP_RCN);
}

private void idee_neu_rumpf(string *puffer)
{
    if (puffer == 0)
    {
        send_message_to(TP, MT_LOOK, MA_READ, 
            wrap("Idee nicht gespeichert."));
        set_pl_tmp(TP, 0, 0);
        return;
    }
    // TODO Inhalt pruefen
    set_pl_tmp(TP, "Inhalt", implode(puffer,"\n"));
    input_to(#'idee_neu_pantheon, INPUT_PROMPT, 
        "Sollen es (S)pieler und Pantheon \n"
        "oder nur das (P)antheon sehen (S/P/~q):");
}

private void idee_neu_titel(string titel)
{
    titel = space(titel);
    if (titel == "" || lower_case(titel) == "~q" || titel == ".")
    {
        send_message_to(TP, MT_LOOK, MA_READ, wrap("Idee abgebrochen."));
        return;
    }
    if (strlen(titel)>70) 
    {
        send_message_to(TP, MT_LOOK, MA_READ, wrap("Titel zu lang (70)."));
        return;
    }
    set_pl_tmp(TP, 0, 0);
    set_pl_tmp(TP, "Titel", titel);
    TP->mini_ed(#'idee_neu_rumpf, 0,
      TP->uses_gmcp_edit() ? 0 : IDEE_TMP_FILE, 
      ([
         MINI_ED_START_TEXT:
            "Gib nun die Ideenzusammenfassung an\n"+
            "Mit '**' oder '.' beenden, mit '~q' abbrechen.\n",
         MINI_ED_TITLE:
            titel,
      ]),
      ([
         MINI_ED_FORCE_WRAP: 1
      ]), 0);    
}

private int idee_neu()
{
    string intro = 
"Bitte gib einen kurzen und prägnanten Titel ein gefolgt von einer "
"Zusammenfassung Deiner Idee. Die Erfahrung zeigt, dass zu lange Texte "
"von anderen nicht gelesen werden. Die Ideen werden den anderen Spielern "
"anonym zur Wahl gestellt, aber die Admins können den Ersteller einsehen. "
"Mit ~q am Zeilen Anfang kannst Du ohne zu speichern abbrechen.";
    
    send_message_to(TP, MT_LOOK, MA_READ, wrap(intro));
    
    input_to(#'idee_neu_titel, INPUT_PROMPT, "Titel:");
    return 1;
}

private void umfrage_neue_antwort(string str, mixed menues, int u_id)
{
    str = space(str);
    get_master();
    switch (str)
    {
    case ".":
    case "~q":
        browse_write_line("Eingabe neue Antwort abgebrochen");
        break;
    case "":
        input_to(#'umfrage_neue_antwort, INPUT_PROMPT, 
                         "Neue Antwort:",menues,u_id);
        return;
    default:
        if (master->add_antwort(u_id, str))
        {
            browse_write_line("Antwort eingefügt.");
            break;
        }
        else
        {
            browse_write_line("Antwort nicht eingefügt.");
            break;
        }
    }
    dynamic_browse(menues);
}

private void umfrage_neu_pantheon(string str, mixed menues, int i_id, 
        string frage)
{
    int flag, u_id;
    switch (lower_case(space(str)))
    {
    case "~q":
    case ".":
        send_message_to(TP, MT_LOOK, MA_READ, wrap("Umfrage abgebrochen."));
        return;
    case "s":
        flag = 0;
        break;
    case "p":
        flag = 1;
        break;
    default:
        input_to(#'umfrage_neu_pantheon, INPUT_PROMPT, 
            "Soll die Umfrage von (S)pieler und Pantheon \n"
            "oder nur vom (P)antheon gesehen werden? (S/P/~q):",
            menues,i_id, frage);
        return;
    }
    u_id = get_master()->add_umfrage(frage,TP_RN,UMFRAGE_S_NEU,i_id,flag);
    if (u_id == 0)
    {
        send_message_to(TP, MT_LOOK, MA_READ, wrap(
            "Umfrage aufgrund eines internen Fehler nicht angelegt."));
        return;
    }
    if (pointerp(menues))
    {
        menues[<1][B_FLAGS] |= BF_DIRTY;
        dynamic_browse(menues + ({([
                        B_TYPE : "umfrage_wahl",
                        UI_OPT_U_ID : u_id,
                        B_START_LINE : 0
                    ]) }) );
    }
    else
    {
        dynamic_browse( ([
                        B_TYPE : "umfrage_wahl",
                        UI_OPT_U_ID : u_id,
                        B_START_LINE : 0
                    ]) );
    }
    browse_write_line("Umfrage angelegt, Antworten einfügen.");
}

private void umfrage_neu_frage(string frage, mixed menues, int i_id)
{
    frage = space(frage);
    if (frage=="~q" || frage==".")
    {
        send_message_to(TP, MT_LOOK, MA_READ, wrap("Umfrage abgebrochen."));
        return;
    }
    if (frage == "" || strlen(frage)> 70)
    {
        input_to(#'umfrage_neu_frage, INPUT_PROMPT, "Frage:", menues, i_id);
        return;
    }
    input_to(#'umfrage_neu_pantheon, INPUT_PROMPT, 
            "Soll die Umfrage von (S)pieler und Pantheon \n"
            "oder nur vom (P)antheon gesehen werden? (S/P/~q):",
            menues,i_id, frage);
}

varargs private int umfrage_neu(mixed menues, int i_id)
{
    string intro =
"Bitte gib die Frage der Umfrage ein, die neu zu erstellen ist. "
"Abbruch jederzeit mit ~q oder einem einzelnen Punkt möglich.";
    send_message_to(TP, MT_LOOK, MA_READ, wrap(intro));
    
    input_to(#'umfrage_neu_frage, INPUT_PROMPT, "Frage:", menues, i_id);
    return 1;
}

private void diskussion_neu_rumpf(string *puffer)
{
    if (puffer == 0)
    {
        send_message_to(TP, MT_LOOK, MA_READ, 
            wrap("Diskussionsbeitrag nicht gespeichert."));
        mixed menues = query_pl_tmp(TP, "Menüs");
        set_pl_tmp(TP, 0, 0);
        dynamic_browse(menues);
        return;
    }
    // TODO Inhalt pruefen
    set_pl_tmp(TP, "Inhalt", implode(puffer,"\n"));
    switch(get_master()->add_diskussionsbeitrag(
            query_pl_tmp(TP, "d_id"),TP_RN,
            query_pl_tmp(TP, "Titel"),
            query_pl_tmp(TP, "Inhalt")))
    {
    case 0:
    case -2:
        browse_write_line("Interner Fehler bei der Beitragserstellung.");
        break;
    case -1: 
        browse_write_line("Diskussion nimmt keine neuen Beiträge an.");
        break;
    case 1:
        browse_write_line("Beitrag angelegt.");
        break;
    break;
    }
    mixed menues = query_pl_tmp(TP, "Menüs");
    menues[<1][B_FLAGS] |= BF_DIRTY;
    set_pl_tmp(TP, 0, 0);
    dynamic_browse(menues);
}

private void diskussion_neu_titel(string titel, mixed menues, int d_id)
{
    titel = space(titel);
    if (titel == "" || lower_case(titel) == "~q" || titel == ".")
    {
        send_message_to(TP, MT_LOOK, MA_READ, wrap("Beitrag abgebrochen."));
        dynamic_browse(menues);
        return;
    }
    if (strlen(titel)>50) 
    {
        send_message_to(TP, MT_LOOK, MA_READ, wrap("Titel zu lang (50)."));
        dynamic_browse(menues);
        return;
    }
    set_pl_tmp(TP, 0, 0);
    set_pl_tmp(TP, "Titel", titel);
    set_pl_tmp(TP, "Menüs", menues);
    set_pl_tmp(TP, "d_id", d_id);
    
    TP->mini_ed(#'diskussion_neu_rumpf, 0,
      TP->uses_gmcp_edit() ? 0 : IDEE_TMP_FILE, 
      ([
         MINI_ED_START_TEXT:
            "Gib nun den Diskussionsbeitrag an\n"+
            "Mit '**' oder '.' beenden, mit '~q' abbrechen.\n",
         MINI_ED_TITLE:
            titel,
      ]),
      ([
         MINI_ED_FORCE_WRAP: 1
      ]), 0);    
}

private int diskussionsbeitrag_neu(mixed menues, int d_id)
{
    string intro =
"Bitte gib den Diskussionsbeitrag mit Titel und Inhalt an. "
"Abbruch jederzeit mit ~q oder einem einzelnen Punkt möglich.";
    send_message_to(TP, MT_LOOK, MA_READ, wrap(intro));
    
    input_to(#'diskussion_neu_titel, INPUT_PROMPT, "Titel:", menues, d_id);
    return 1;
}


#define HILFE_TEXT \
"Im folgenden wird eine alternative kurzform in Klammern angegeben:\n"\
"idee:neu(i:n) legt eine neue Idee mit Standardumfrage an.\n" \
"idee:wahl(i:w) zeigt die aktiv zur Wahl stehenden Ideen in einem Menu an.\n" \
"idee:offeneStimmen (i:o) zeigt nur die Ideen an, deren Wahl aussteht.\n" \
"idee:meine(i:m) zeigt die eigenen Ideen an, unabhaengig vom Status.\n" \
"idee:aktuell(i:a) zeigt die aktuell zur Diskussion stehende Idee an.\n" \
"idee:diskussion(i:d) zeigt die zur Diskussion stehenden Ideen an.\n" \
"idee:ignoriert zeigt alle ignorierten Ideen an.\n" \
"uiko:lerne   Falls noetig, verreist Uiko kurz, um was neues zu lernen.\n" \
"uiko:verjage  verjagt den Kobold.\n"

#define HILFE_TEXT_ADMIN \
"Befehle nur fuer Admins:\n" \
"idee:bereit(i:b) zeigt die auf Freigabe wartenden Ideen in einem Menu an.\n" \
"idee:alle zeigt Ideen unabhaengig vom Status an.\n" \
"idee:aktuellaus deaktiviert die aktuelle Idee wieder.\n" \
"idee:auswertung-s zeigt die Auswertung aller Spielerideen an.\n" \
"idee:auswertung-p zeigt die Auswertung aller Pantheonsideen an.\n" \
"idee:auswertung-sp zeigt die Auswertung aller Ideen(Spieler und Pantheon)an.\n" \
"umf:neu (u:n) legt eine neue Umfrage unabhaengig von einer Idee an.\n"\
"uiko:sql <query> setzt ein sql-Kommando an die Datenbank ab.\n" \
"uiko:tablelist <table> zeigt alle oder eine bestimmte Tabelle an.\n"\
"uiko:dbglog zeigt das debuglog der Datenbank an.\n"

int idee_cmd(string str)
{
    if (!check_security())
        return 0;
    str = lower_case(space(str)); // behandelt zuviele spaces und 0=>""
    switch (str)
    {
    default:
    case "":
    case "hilfe":
    case "?":
        send_message_to(TP, MT_LOOK, MA_READ, 
            query_commander(TP) ? HILFE_TEXT+HILFE_TEXT_ADMIN : HILFE_TEXT
            );
        return 1;
    case "n":
    case "neu":
        return idee_neu();
    case "a":
    case "aktuell":
        dynamic_browse( ([ B_TYPE:"idee_aktuell" ]) );
        return 1;
    case "aktuellaus":
        if (query_commander(TP))
        {
            get_master()->set_aktuelle_idee(0);
            browse_write_line("Aktuelle Idee zurückgesetzt.");
        }
        else
            browse_write_line("Befehl steht nicht zur Verfügung.");
        return 1;
    case "alle":
        if (query_commander(TP))
            dynamic_browse( ([ B_TYPE:"idee_uebersicht",
                               UI_OPT_MENUTYPE : UI_MENUTYPE_ALLE,
                           ]) );
        else
            browse_write_line("Befehl steht nicht zur Verfügung.");
        return 1;
    case "w":
    case "wahl":
        dynamic_browse( ([ B_TYPE:"idee_uebersicht",
                           UI_OPT_MENUTYPE : UI_MENUTYPE_WAHL,
                           UI_OPT_STATUS : ({UMFRAGE_S_AKTIV,
                                             UMFRAGE_S_OFFEN})
                         ]) );
        return 1;
    case "o":
    case "offen":
    case "offenestimmen":
        dynamic_browse( ([ B_TYPE:"idee_uebersicht",
                           UI_OPT_MENUTYPE : UI_MENUTYPE_OFFEN,
                           UI_OPT_UMFRAGE_OFFEN : 1,
                           UI_OPT_STATUS : ({UMFRAGE_S_AKTIV,
                                             UMFRAGE_S_OFFEN})
                         ]) );
        return 1;
    case "m":
    case "meine":
        dynamic_browse( ([ B_TYPE:"idee_uebersicht",
                           UI_OPT_MENUTYPE : UI_MENUTYPE_OWN,
                           UI_OPT_ERSTELLER : TP_RN]) );
        return 1;
    case "b":
    case "bereit":
        if (query_commander(TP))
            dynamic_browse( ([ B_TYPE:"idee_uebersicht",
                               UI_OPT_MENUTYPE : UI_MENUTYPE_BEREIT,
                               UI_OPT_STATUS : ({UMFRAGE_S_BEREIT})
                           ]) );
        else
            browse_write_line("Befehl steht nicht zur Verfügung.");
        return 1;
    case "d":
    case "diskussion":
            dynamic_browse( ([ B_TYPE:"idee_uebersicht",
                               UI_OPT_MENUTYPE : UI_MENUTYPE_DISKU,
                               UI_OPT_DISKUSSION : 1
                           ]) );
            return 1;
    case "keinediskussion":
        if (query_commander(TP))
            dynamic_browse( ([ B_TYPE:"idee_uebersicht",
                               UI_OPT_MENUTYPE : UI_MENUTYPE_NDISKU,
                               UI_OPT_OHNE_DISKUSSION : 1
                           ]) );
        else
            browse_write_line("Befehl steht nicht zur Verfügung.");
        return 1;
    case "ignoriert":
            dynamic_browse( ([ B_TYPE:"idee_uebersicht",
                               UI_OPT_MENUTYPE : UI_MENUTYPE_IGNORIERT,
                               UI_OPT_IGNORELIST : 2
                           ]) );
        return 1;
    case "auswertung-s":
        if (query_commander(TP))
            dynamic_browse( ([ B_TYPE:"ideen_auswertung",
                           ]) );
        else
            browse_write_line("Befehl steht nicht zur Verfügung.");
        return 1;
    case "auswertung-p":
        if (query_commander(TP))
            dynamic_browse( ([ B_TYPE:"ideen_auswertung",
                               UI_OPT_PANTHEON : -1,
                           ]) );
        else
            browse_write_line("Befehl steht nicht zur Verfügung.");
        return 1;
    case "auswertung-sp":
        if (query_commander(TP))
            dynamic_browse( ([ B_TYPE:"ideen_auswertung",
                               UI_OPT_PANTHEON : 1,
                           ]) );
        else
            browse_write_line("Befehl steht nicht zur Verfügung.");
        return 1;
    }
}

int umfrage_cmd(string str)
{
    if (!check_security())
        return 0;
    str = lower_case(space(str)); // behandelt zuviele spaces und 0=>""
    switch (str)
    {
    default:
    case "":
    case "hilfe":
    case "?":
        send_message_to(TP, MT_LOOK, MA_READ, 
            query_commander(TP) ? HILFE_TEXT+HILFE_TEXT_ADMIN : HILFE_TEXT
            );
        return 1;
    case "n":
    case "neu":
        if (!query_commander(TP))
        {
            FAIL("Kommando ist reserviert.\n");
        }
        return umfrage_neu();
    case "w":
    case "wahl":
        if (query_commander(TP))
            dynamic_browse( ([ B_TYPE:"x_umfragen_wahl",
                           ]) );
        else
            browse_write_line("Befehl steht nicht zur Verfügung.");
        return 1;
    }
   return 0;
}

int uiko_cmd(string str)
{
    if (!check_security())
        return 0;
    string * parts = explode(space(str), " ");
    string param = implode(parts[1..]," ");
    switch (lower_case(parts[0]))
    {
    default:
    case "":
    case "hilfe":
    case "?":
        send_message_to(TP, MT_LOOK, MA_READ, 
            query_commander(TP) ? HILFE_TEXT+HILFE_TEXT_ADMIN : HILFE_TEXT
            );
        return 1;
    case "lern":
    case "lerne":
    case "lernen":
        return uiko_lerne();
    case "verjage":
        send_message_to(TP, MT_NOISE, MA_COMM, wrap(
            "Der Kobold schaut dich traurig an bevor er verschwindet "
            "und flüstert dir zu: Du weißt ja, "
            "wo du mich wiederfinden kannst."));
        call_out("remove",0);
        return 1;
    case "sql":
        if (!query_commander(TP)) 
            FAIL("Kein Zugriff");
        return get_master()->sql(param);
    case "tablelist":
        if (!query_commander(TP)) 
            FAIL("Kein Zugriff");
        return get_master()->tablelist(param);
    case "dbglog":
        if (!query_commander(TP)) 
            FAIL("Kein Zugriff");
        TP->more(get_master()->dbglog());
        return 1;
    }
   return 1;
}

void init()
{
    switch (check_ob(TP))
    {
    case IST_ADMIN: 
    case IST_GOTT:
    case IST_ENGEL:
    case IST_SPIELER:
        add_action("umfrage_cmd","umf:",AA_NOSPACE);
        add_action("umfrage_cmd","u:",AA_NOSPACE);
        add_action("idee_cmd", "idee:",AA_NOSPACE);
        add_action("idee_cmd", "i:",AA_NOSPACE);
        add_action("uiko_cmd", "uiko:",AA_NOSPACE);
        PDBG("uiko:init: "+TP_RCN);
    }
}

private string get_menue_path(mixed menues)
{
    if (mappingp(menues))
    {
        return menues[B_TYPE];
    }
    if (pointerp(menues)&&sizeof(menues))
    {
        string path = menues[<1][B_TYPE];
        for (int i=sizeof(menues)-2;i>=0 ; i--)
        {
            path += "/" + menues[i][B_TYPE];
        }
        return path;
    }
    return "";
}

private string get_status(int st)
{
    switch (st)
    {
    case UMFRAGE_S_GELOESCHT:  return "Gelöscht";
    case UMFRAGE_S_NEU:        return "Neu";
    case UMFRAGE_S_STANDARD:   return "Standard";
    case UMFRAGE_S_BEREIT:     return "Bereit";
    case UMFRAGE_S_AKTIV:      return "Aktiv";
    case UMFRAGE_S_OFFEN:      return "Offen";
    case UMFRAGE_S_BEENDET:    return "Beendet";
    case UMFRAGE_S_ABGELEHNT:  return "Abgelehnt";
    case UMFRAGE_S_ARCHIVIERT: return "Archiviert";
    default:                   return "";
    }
}

private int get_status_id(string st)
{
    switch (st)
    {
    case "Gelöscht":  return UMFRAGE_S_GELOESCHT;
    case "Neu":        return UMFRAGE_S_NEU;
    case "Standard":   return UMFRAGE_S_STANDARD;
    case "Bereit":     return UMFRAGE_S_BEREIT;
    case "Aktiv":      return UMFRAGE_S_AKTIV;
    case "Offen":      return UMFRAGE_S_OFFEN;
    case "Beendet":    return UMFRAGE_S_BEENDET;
    case "Abgelehnt":  return UMFRAGE_S_ABGELEHNT;
    case "Archiviert": return UMFRAGE_S_ARCHIVIERT;
    default:                   return -1;
    }
}

private mixed neue_diskussion(string was, int id, int flags)
{
    get_master();
    int i = 0;
    if (flags & 1)
    {
        switch(master->add_diskussion(was,id,0,UMFRAGE_S_BEREIT))
        {
        case 1: 
            i++; 
        case -1:
            break;
        case -2:
        case 0:
            browse_write_line("Interner Fehler beim Diskussion anlegen");
            return B_DONE;
           
        }
    }
    if (flags & 2)
    {
        switch(master->add_diskussion(was,id,1,UMFRAGE_S_BEREIT))
        {
        case 1: 
            i++; 
        case -1:
            break;
        case -2:
        case 0:
            browse_write_line("Interner Fehler beim Diskussion anlegen");
            return B_DONE;
           
        }
    }
    switch (i)
    {
    default:
    case 0: 
        browse_write_line("Keine Diskussion angelegt, schon vorhanden.");
        return B_DONE;
    case 1:
        browse_write_line("Eine Diskussion angelegt.");
        return B_DONE;
    case 2:
        browse_write_line("Zwei Diskussionen angelegt.");
        return B_DONE;
    }
}

