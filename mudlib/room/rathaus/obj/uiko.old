nomask int query_no_move() 
{
    return 1;
}

private object get_master()
{
    if (objectp(master))
        return master;
    master = find_object(UMFRAGE_MASTER) || touch(UMFRAGE_MASTER);
    return master;
}

private varargs int debuglog(string msg, int severity, string user, 
    string category)
{
    return get_master()->debuglog(msg,severity||DB_DBGLVL_DEBUG,
        user||TP_RN,category||"uiko");
}

private int query_commander(object pl)
{
    return adminp(pl);
}

private int check_ob(object env)
{
    if (!env || guestp(env)) 
        return 0;
    if (env->is_room())
        return 0; // IST_RAUM; deaktiviert, da nicht getestet.
    else if (adminp(env))
        return IST_ADMIN;
    else if (wizp(env))
        return IST_GOTT;
    else if (hlpp(env))
        return IST_ENGEL;
    else if (playerp(env))
        return IST_SPIELER;
    return 0;
}

private void check_env(object pl)
{
    umgebung = check_ob(ENV_TO);
    if (clonep() && umgebung == 0 )
    {
        call_out("remove",0);
        send_message_to( ({ pl }),MT_LOOK, MA_LOOK, wrap(
            "Der Kobold verschwindet so schnell wie er erschien."));
    }
}

string query_long(object viewer)
{
    string l = "Ein winziger Umfrage- und Ideenkobold (kurz UIKO), ";
    if (umgebung == IST_RAUM)
    {
        l += "der in einer Ecke hockt. ";
    }
    else if (viewer == ENV_TO)
    {
        l += "der Dir helfend auf der Schulter hockt. ";
    }
    else
    {
        l += "der "+ihm(ENV_TO)+" helfend auf der Schulter hockt.";
        return wrap(l);
    }
    l += "Die Befehlsliste/Hilfe ist mit idee:? bzw. i:? einsehbar.";
    return wrap(l);
    
}

private void check_version()
{
    int db_neu = get_master()->get_current_version();
    if (db_version == db_neu)
    {
        return;
    }
    db_version = db_neu;
    // TODO Nachricht ueber alle Aenderungen??
}

mixed query_auto_load()
{
    return ([
           "DB_VERSION" : db_version,
           ]);
}

void init_arg(mixed data)
{
    if (!mappingp(data))
    	return;
    if (member(data,"DB_VERSION"))
    {
        db_version = data["DB_VERSION"];
        call_out(#'check_version, 4);
    }
}

private void set_pl_tmp(object pl, string key, mixed value)
{
    if (!playerp(pl))
        return;
    if (!stringp(key))
    {
        m_delete(pl_tmp, pl);
        return;
    }
    if (value == 0)
    {
        if (!member(pl_tmp,pl))
        {
            return; //nothing to delete
        }
        else if (!member(pl_tmp[pl],key))
        {
            return; // key not existent, nothing to delete
        }
        else
        {
            m_delete(pl_tmp[pl],key);
            if (!sizeof(pl_tmp[pl]))
            {
                m_delete(pl_tmp, pl);
            }
        }
    }
    else
    {
        if (!member(pl_tmp,pl))
        {
            pl_tmp[pl] = ([ key : value ]);
        }
        else
        {
            pl_tmp[pl][key] = value;
        }
    }
}

private mixed query_pl_tmp(object pl, string key)
{
    if (member(pl_tmp,pl) && member(pl_tmp[pl],key))
        return pl_tmp[pl][key];
    return 0;
}

//---------------------------------------------------------------------------
#define L_DATA_UMFRAGE 0
#define L_DATA_THEMA   1
#define L_DATA_VARIANT 2
#define L_DATA_FRAGE   3
#define L_DATA_ANTWORT 4

#define L_OPTIONS       "ui:local:options"
#define L_DATA          "ui:local:data"
#define L_SONSTIGE      "ui:local:sonstige"
#define L_MULTI         "ui:local:multi"
#define L_ANTWORTEN     "ui:local:antworten"

private void loop_x_umfrage(mapping l_options,mapping *l_data);


//---------------------------------------------------------------------------

static mixed auswahl_x_antworten_init(mapping old)
{
    old[B_START_LINE] = 0;
    if (old[L_SONSTIGE])
        old[B_NUM_LINES] -= 2;
    else
        old[B_NUM_LINES] -= 1;
}

static int auswahl_x_antworten_total(mapping menue)
{
    return get_master()->get_xantworten(
        menue+([UI_OPT_COUNTALL:1]));
}

static string * auswahl_x_antworten_display(mapping menue)
{
    string * lines = ({});
    mapping cache = ([]);
    int i;
    mapping * antworten = get_master()->get_xantworten(menue
            +([UI_OPT_LIMIT:  menue[B_NUM_LINES],
            UI_OPT_OFFSET: menue[B_CURRENT_LINE],
            UI_OPT_MAPPING : 1]) );
    mapping frage = master->get_xfrage(menue[UI_OPT_FRAGE]);
    if (!mappingp(frage)) 
    {
        return ({"Frage vergessen."});
    }
    lines += frage[UI_OPT_FRAGE];
    if (antworten == 0 || sizeof(antworten) <= 0)
    {
        if (menue[L_SONSTIGE])
        {
            return lines + ({"Keine Antwort vorhanden",
                "s <text> um eine Antwort zu ergänzen."});
        }
        else
        {
            return lines+({"Keine Antwort vorhanden"});
        }
    }
    for (i=0;i<sizeof(antworten);i++)
    {
        int ix = i+menue[B_CURRENT_LINE]+1;
        cache[ix] = antworten[i][UI_OPT_XA_ID];
        lines += ({ sprintf("%02d %s",
            ix,antworten[i][UI_OPT_ANTWORT]||"") });
    }
    if (menue[L_SONSTIGE] && i>=menue[B_END_LINE])
    {
        lines += ({"s <text> um eine Antwort zu ergänzen."});
    }
    menue[UI_OPT_CACHE] = cache;
    return lines;
}

static string auswahl_x_antworten_prompt(mapping menue)
{
    string str,sonst="";
    if (member(menue,L_SONSTIGE))
    {
        sonst = ",s";
    }
    if (member(menue,L_MULTI))
    {
        if (menue[L_MULTI]>1)
        {
            str = sprintf("%d aus %d Antworten auswählen [<nr>,f%s]",
                menue[L_MULTI],menue[B_END_LINE],sonst);
        }
        else
        {
            str = sprintf("Beliebige Antworten auswählen (%d,%d) [<nr>,f%s]",
                menue[B_CURRENT_LINE]+1,menue[B_END_LINE],sonst);
        }
    }
    else
    {
        str = sprintf("Eine Antwort auswählen (%d,%d) [<nr>%s]",
                menue[B_CURRENT_LINE]+1,menue[B_END_LINE],sonst);
    }
    return str;
}

static mixed auswahl_x_antworten_action(string str, mapping * menues)
{
    mapping menue = menues[<1] , antworten = menue[L_ANTWORTEN];
    mapping cache = menue[UI_OPT_CACHE];
    int ix = to_int(space(str));
    if (member(cache,ix))
    {
        if (!mappingp(antworten) || !member(menue,L_MULTI))
        {
            antworten = ([ cache[ix] : 1]);
            browse_write_line("Antwort ausgewählt.");
        }
        else if (member(antworten,cache[ix]))
        {
            m_delete(antworten,cache[ix]);
            browse_write_line("Antwort gelöscht.");
        }
        else
        {
            antworten[cache[ix]] = 1;
            browse_write_line("Antwort gewählt.");
        }
        if (!member(menue,L_MULTI))
        {
            // mapping m_antwort = get_master()->get_x_antwort(cache[ix]);
            
        }
        else
        {
            menue[L_ANTWORTEN] = antworten;
            return B_REBUILT;
        }
    }
    else if (ix != 0)
    {
        browse_write_line("Zahl außerhalb des angezeigten Zahlenbereichs.");
        return B_DONE;
    }
}

//---------------------------------------------------------------------------

private void inp_gilde(string str,mapping l_options,mapping *l_data)
{
    if (str == "~q" || str == "q")
    {
        browse_write_line("Umfrage/Eingabe abgebrochen.");
        return;
    }
    mixed* l = get_master()->get_x_gilden(
        l_data[L_DATA_UMFRAGE][UI_OPT_UNIFIED_ID],
        l_options[UI_OPT_USER_NAME]);
    int ix = to_int(space(str))-1;
    if (ix < 0 || ix >= sizeof(l))
    {
        browse_write_line("Ungültige Zahl.");
        input_to(#'inp_gilde,INPUT_PROMPT,"Gilde wählen: ",l_options,l_data);
        return;
    }
    if (l[ix][0]!=0)
    {
        browse_write_line("Gilde nicht nochmal auswählbar.");
        input_to(#'inp_gilde,INPUT_PROMPT,"Gilde wählen: ",l_options,l_data);
        return;
    }
    string gilde = l[ix][1];
    l_options[UI_OPT_GILDE] = gilde;
    // TODO replacement of gilde in l_data[L_DATA_THEMA]
    l_data += ({([ UI_OPT_GILDE : gilde,UI_OPT_UNIFIED_ID : gilde,
            UI_OPT_TITLE: gilde ])});
    loop_x_umfrage(l_options,l_data);
}
private int inp2_gilde(mapping l_options,mapping *l_data)
{
    int cnt_done = 0;
    mixed* l = get_master()->get_x_gilden(
        l_data[L_DATA_UMFRAGE][UI_OPT_UNIFIED_ID],
        l_options[UI_OPT_USER_NAME]);
    if (!sizeof(l))
    {
        debuglog("Datenfehler l",DB_DBGLVL_ERROR,TP_RN,
                "uiko:inp2_gilde");
        return 0;
    }
    string line;
    for (int i=0;i<sizeof(l);i++)
    {
        if (l[i][0]) 
        {
            cnt_done++;
            line = sprintf("%02d [X] %s",i+1,l[i][1]);
        }
        else
        {
            line = sprintf("%02d [.] %s",i+1,l[i][1]);
        }
        browse_write_line(line);      
    }
    if (cnt_done >= sizeof(l))
    {
        return -2; // end of guild data
    }
    input_to(#'inp_gilde,INPUT_PROMPT,"Gilde wählen: ",l_options,l_data);
    return -1; // InputData.
}

private string update_unified_path(mapping l_options,mapping *l_data)
{
    string *uids = ({});
    for (int i = 0;i<sizeof(l_data);i++)
    {
        uids += ({ l_data[i][UI_OPT_UNIFIED_ID] });
    }
    l_options[UI_OPT_UNIFIED_PATH] = uids;
    return l_options[UI_OPT_UNIFIED_ID] = implode(uids,"|");;
}

private int get_next_x_thema(mapping l_options,mapping *l_data)
{
    mapping l_thema;
    switch (sizeof(l_data))
    {
        case L_DATA_UMFRAGE:
            debuglog("Parameterfehler l_data",DB_DBGLVL_ERROR,TP_RN,
                "uiko:get_next_x_thema");
            return 0;
        case L_DATA_THEMA:
            l_thema = master->get_next_x_thema(
                    l_data[L_DATA_UMFRAGE][UI_OPT_XU_ID],0);
            break;
        default: 
            l_thema = l_data[L_DATA_UMFRAGE];
            if (strstr(l_thema[UI_OPT_UNIFIED_ID],"<gilde>")!=-1)
            {
                break;
            }
            else
            {
                l_thema = master->get_next_x_thema(
                    l_data[L_DATA_UMFRAGE][UI_OPT_XU_ID],
                    l_data[L_DATA_THEMA][UI_OPT_SEQUENCE]);
                break;
            }
    }
    if (!mappingp(l_thema))
    {
        return -3; // kein weiteres Thema mehr...
    }
    l_data = l_data[0..0] + ({ l_thema });
    if (strstr(l_thema[UI_OPT_UNIFIED_ID],"<gilde>")!=-1)
    {
        switch (inp2_gilde(l_options,l_data))
        {
            case -1: // input_to
                return -1;
            case 0: // Fehler
                return 0;
            case -2: // gilde fertig
                l_thema = master->get_next_x_thema(
                    l_data[L_DATA_UMFRAGE][UI_OPT_XU_ID],
                    l_data[L_DATA_THEMA][UI_OPT_SEQUENCE]);
                if (!mappingp(l_thema))
                {
                    return -3; // kein weiteres Thema mehr...
                }
                // <gilde> soll nur einmal vorkommen!
                l_data = l_data[0..0] + ({ l_thema });
                
        }
        // return -2: end of gilden, -1 input_to aktiv, 0 fehler.
    }
    l_data += ({([
            UI_OPT_UNIFIED_ID:"NONV",
            UI_OPT_TITLE:l_thema[UI_OPT_TITLE] 
            ])});
    return 1;
}

private int get_next_x_frage(mapping l_options,mapping *l_data)
{
    mapping l_frage;
    switch (sizeof(l_data))
    {
        case L_DATA_UMFRAGE: 
        case L_DATA_THEMA: 
            debuglog("Parameterfehler l_data",DB_DBGLVL_ERROR,TP_RN,
                "uiko:get_next_x_frage");
            return 0;
        case L_DATA_VARIANT:
            l_frage = master->get_next_x_frage(
                    l_data[L_DATA_THEMA][UI_OPT_XT_ID],0);
            break;
        default: 
            l_frage = master->get_next_x_thema(
                    l_data[L_DATA_THEMA][UI_OPT_XT_ID],
                    l_data[L_DATA_FRAGE][UI_OPT_SEQUENCE]);
            break;
    }
    if (!mappingp(l_frage))
    {
        return -3; // keine frage mehr
    }
    l_data = l_data[0..2] + ({ l_frage });
    return 1;
}

private void list_zeit3_3_10(string val)
{
    browse_write_line("(1) weniger als drei Monate");
    browse_write_line("(2) weniger als drei Jahre");
    browse_write_line("(3) weniger als 10 Jahre");
    browse_write_line("(4) mehr als 10 Jahre");
