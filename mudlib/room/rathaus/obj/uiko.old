//---------------------------------------------------------------------------

private void uiko_will_lernen()
{
    send_message_to( ({ENV_TO}), MT_NOISE, MA_COMM, wrap_say(
        "Uiko jammert dir leise ins Ohr:","Lass mich bitte mit uiko:lerne "
        "etwas dazulernen."));
}

int check_current()
{
    if (clonep())
    {
        if (__FILE__->check_current() > object_time())
        {
            call_out(#'uiko_will_lernen, 3+random(7));
            return 0;
        }
        return object_time();
    }
    else
    {
        return program_time();
    }
}

private void abbruch_lehrstunde(object pl, object old, object new)
{
    if (pl && pl->query_ghost())
    {
        pl->close_con();
    }
    send_message_to(({pl}), MT_LOOK, MA_LOOK, wrap(
            "Uiko ist auf seiner Reise wohl mit einem Kuscheli "
            "zusammengestoßen und kommt nicht wieder. Du wirst Dir bei Leo "
            "einen neuen Uiko holen müssen."));
    if (old)
    {
        destruct(old);
    }
    if (new)
    {
        destruct(new);
    }
}

void lehrstunde(object pl, object old)
{
    if (clonep() || !playerp(pl) || !objectp(old) || !clonep(old) 
        || ENV(old)!=pl || program_name(old) != __FILE__ 
        || object_time(old) >= program_time())
    {
        send_message_to(pl, MT_LOOK, MA_LOOK, wrap(
            "Uiko braucht momentan nichts lernen, es jammert schon, "
            "sollte es nötig sein."));
        return;
    }
    send_message_to(pl, MT_LOOK, MA_LOOK, wrap(
        "Uiko macht sich reisefertig und verschwindet mit einem Plopp."));
    closure cl = #'abbruch_lehrstunde;
    call_out(cl ,0, pl, old, 0);
    mixed data = old->query_auto_load();
    old->remove();
    if (old)
        destruct(old);
    object new = clone_object(__FILE__);
    new->init_arg(data);
    remove_call_out(cl);
    call_out(cl ,0, pl, old, new);
    if (pl->query_ghost())
    {
        pl->open_con();
    }
    int mr = new->move(pl, ([MOVE_FLAGS:MOVE_ERR_REMOVE]));
    if (pl->query_ghost())
    {
        pl->close_con();
    }
    switch (mr)
    {
    case MOVE_OK:
        send_message_to(pl, MT_LOOK, MA_LOOK, wrap(
            "Uiko erscheint wohlgelaunt wieder."));
        break;
    default:
        send_message_to(pl, MT_LOOK, MA_LOOK, wrap(
            "Uiko bleibt in den weitläufigen Strukturen des "
            "Raum-Zeit-Kontinuums verloren. Du wirst Dir bei Leo einen "
            "neuen Uiko holen müssen."));
        break;
    }
    remove_call_out(cl);
}

private int uiko_lerne()
{
    __FILE__->lehrstunde(TP,TO);
    return 1;
}


void test_clones()
{
    if (!clonep())
    {
        rclones -= ({ 0 });
        rclones->check_current();
    }
}

void msg_to_clones(string pre, string msg)
{
    if (!clonep())
    {
        rclones -= ({ 0 });
        send_message_to( map(rclones, (: ENV($1) :)), MT_NOISE, MA_COMM, 
                wrap_say(pre,msg));
    }
}


void register_clone(object ob)
{
    if (!clonep() && objectp(ob) && program_name(ob) == __FILE__)
    {
        rclones -= ({ 0, ob });
        rclones += ({ ob });
        //PDBG(sprintf("uiko %Q registriert",ob));
    }
}

void reset()
{
    // Momentan muss reset noch nicht im create aufgerufen werden
    check_current();
}

void create()
{
    "*"::create();
    initialize("kobold",100);
    set_weight(0);
    set_adjektiv("klein");
    set_name("uiko");
    set_short("Uiko, ein Umfrage- und Ideenkobold");
    set_gender("maennlich");
    set_id(({"uiko","umfragekobold","ideenkobold","kobold"}));
    set_long( "Ein winziger Umfrage- und Ideenkobold kurz Uiko, "
            "der helfend auf Deiner Schulter hockt.");
    set_rollen_dirs(0); //Keine Rollen
    set(P_LOOK_MSG, ""); // Kein Anzeichen, dass der Eigentuemer es anschaut.
    
    init_security_trust_mudlib();
    init_security_for_actions();
    add_security_condition((: return adminp($1); :));
    
    clone_object("/obj/soul")->move(this_object());
    close_con();
    call_out(#'check_env,0, TI); // nach dem Move...
    if (clonep())
        __FILE__->register_clone(this_object());
    else
        call_out("test_clones",0);
}

public void transfer_clones(object * obs)
{
    string * on1 = explode(object_name(TO),"/");
    string * on2 = explode(object_name(PO),"/");
    if (implode(on1[..<2],"/") != implode(on2[..<2],"/"))
        return;
    if ( on2[<1] != ("$"+on1[<1]+"$"))
        return;
    if (!clonep() && pointerp(obs))
    {
        rclones -= obs;
        rclones += obs;
        rclones -= ({ 0 });
    }
}

void abort_renewal() 
{
}
void finish_renewal(object neu) 
{
    if (!clonep())
    {
        neu->transfer_clones(rclones);
    }
}
void prepare_renewal() 
{
}

