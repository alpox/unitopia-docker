     Wer(ork)+" haette "+wen(who,ART_ER)+" am liebsten davongejagt."
        liefert:
     "Der Ork haette ihn am liebsten davongejagt."

     Wer(ork)+" patscht "+wem(who)+" auf "+
     wen((["name"  :"finger",
	   "gender":"maennlich",
	   "plural":1]), ART_SEIN, 0, who)+"."
        liefert:
     "Der Ork patscht Anton auf seine Finger."


