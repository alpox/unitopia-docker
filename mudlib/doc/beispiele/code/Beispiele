int drink_is_me(string str)
{
     // trinke phiole
    if (me(str))
        return 1;

     // trinke flüssigkeit [aus phiole]
    if (here(str, "flüssigkeit # special # id"))
        return 1;

     // aus phiole
    if (left(str, 4) == "aus ")
    {
        if (me(substr(str,5)))
            return 1;
    }

    return 0;
}
