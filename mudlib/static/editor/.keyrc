#
# Diese Datei enthält die Tastatur-Codes für die einzelnen
# Editor-Funktionen.
#
# Wer möchte, kann die Settings nach Wunsch abändern, und in
# ~/.keyrc ablegen, wo der Editor sie dann beim nächsten Start 
# automatisch findet und einlädt.
#
# Mit "xed #" startet man ein kleines Utility, mit dessen Hilfe
# man die Tastatur-Codes auch ohne Dokumentation herausfinden kann.
#
#############################################################################
# Bezeichnung    ID   Taste      Keycodes
#############################################################################

  DOWN           -1   CrsDown     27, 91, 66
  UP             -2   CrsUp       27, 91, 65
  LEFT           -3   CrsLeft     27, 91, 68
  RIGHT          -4   CrsRight    27, 91, 67
  BACKSPACE      -5   Backspace    8
#  BACKSPACE      -5   Backspace  127
#  DELETE         -6   Delete     127
  DELETE         -6   Delete      27, 91, 51, 126
  INSERT         -7   Insert      27, 91, 50, 126
  SCR_DOWN       -8   ScrDown     27, 91, 54, 126
  SCR_DOWN       -8   ^V          22
  SCR_UP         -9   ScrUp       27, 91, 53, 126
  SCR_UP         -9   ^U          21
  HOME          -10   ^A           1
  END           -11   ^E           5
  FIRSTLINE     -12   ^KU         11, 21
  LASTLINE      -13   ^KV         11, 22
  DELETE_LINE   -14   ^Y          25
  GOTO_LINE     -15   ^KG          7
  NEXT_WORD     -16   ^W          23
  LAST_WORD     -17   ^Q          17
  END_EDITOR    -21   ^C           3
  END_EDITOR    -21   ^KX         11, 24
  SAVE          -22   ^DS          4, 19
  SAVE          -22   ^DW          4, 23
  LOAD          -23   ^DL          4, 12
  MERGE         -24   ^DE          4,  5
  M_TEMPLATE    -25   ^DT          4, 20
  BLOCK_BEGIN   -30   ^KB         11,  2
  BLOCK_END     -31   ^KK         11, 11
  BLOCK_END     -31   ^KE         11,  5
  BLOCK_DELETE  -32   ^KD         11,  4
  BLOCK_COPY    -33   ^KC         11,  3
  BLOCK_MOVE    -34   ^KM         11, 13
  BLOCK_LEFT    -35   ^KL         11, 12
  BLOCK_RIGHT   -36   ^KR         11, 18
  BLOCK_UNMARK  -37   ^KL         11, 10
  BLOCK_SAVE    -38   ^KS         11, 19
  BLOCK_SAVE    -38   ^KW         11, 23
  HELP          -40   ^O          15
  REFRESH       -41   ^R          18
  FIND          -50   ^F           6
  FIND_NEXT     -51   ^N          14
  FIND_LAST     -52   ^B           2
  FIND_QUICK    -53   ^X          24

