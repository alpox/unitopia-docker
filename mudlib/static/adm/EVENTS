###############################################################################
#
# Events
# ------
#
# <fileformat> :=
#    <defaults>
#    <emptyline>
#    <kanal>
#    <emptyline>
#    <kanal>
#    <emptyline>
#    ...
#
# <kanal> :=
#    <key><whitespace><data>
#    <key><whitespace><data>
#    ...
#
# <defaults> :=
#    <kanal>                                         // ohne key: nr
# 
# <key> :=
#   nr | name | level | invis | distrib | func | gilde | desc | musthave
#
# <data> :=
#   <stringconstant> | <integerconstant>             // je nach key
#
# nr:		Numer unter der dieses Event gespeichert wird. (int)
# name:		alphanumerische Bezeichnug des Eventkanals (string)
# level:	Mindestlevel, ab der Meldungen an den client gereicht werden (i)
# invis:	1 = Meldungen werden ausgegeben auch wenn der origin invis ist
#               0 = Meldungen nur von sichtbaren Objekten. (int)
# distrib:	x = Dieser Kanal wird über udp gesteuert (->/adm/DISTRIB)
#               0 = Dieser Kanal ist Mud lokal (int)
# func:		Formatierfunktion für Meldungen über diesen Kanal (string)
# gilde:	Gildenname (query_gilde()) (string)
# desc:		Kurzbeschreibung des Kanals (string)
# ro:		read_only kanal (not implemeted yet)
# musthave:     Um diesen Kanal empfangen zu können muss man zusätzlich
#               einen Gegenstand dabei haben (present!) mit dieser ID
# undisclosed:	true: Ein Spieler sieht nicht die Zuhörer
#		false (Standard): Ein Spieler sieht alle weiteren Zuhörer.
# sys_log:      Dieser Kanal soll mitgeloggt werden. Es folgt der Dateiname.
#

###############################################################################
#
# Defaultwerte, müssen bei den Kanälen unten nicht extra aufgeführt werden.
# müssen als erstes 'Paket' stehen.

level	1
invis	1

